{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false
  },
  "include": [
    "server.ts",
    "lpc-tools.ts",
    "adp-tools.ts",
    "lrs-tools.ts",
    "ac-tools.ts",
    "../../applications/learner-performer-companion/src/**/*.ts",
    "../../applications/agent-development-practice/src/**/*.ts",
    "../../applications/lrs-adapter/src/**/*.ts",
    "../../applications/agent-collective/src/**/*.ts",
    "../../applications/_shared/scorm/**/*.ts",
    "../../applications/_shared/vc-jwt/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
