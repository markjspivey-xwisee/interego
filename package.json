{
  "name": "@interego/core",
  "version": "0.2.0",
  "description": "Reference implementation of Interego 1.0 — a compositional framework for typed graph contexts over RDF 1.2 Named Graphs, with PGSL substrate, harness ontology, and runtime evaluation",
  "author": "Interego",
  "license": "CC-BY-4.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./model": {
      "import": "./dist/model/index.js",
      "types": "./dist/model/index.d.ts"
    },
    "./rdf": {
      "import": "./dist/rdf/index.js",
      "types": "./dist/rdf/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./sparql": {
      "import": "./dist/sparql/index.js",
      "types": "./dist/sparql/index.d.ts"
    },
    "./solid": {
      "import": "./dist/solid/index.js",
      "types": "./dist/solid/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "docs/ns/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "rdf",
    "rdf-star",
    "named-graphs",
    "context",
    "provenance",
    "prov-o",
    "shacl",
    "json-ld",
    "sparql",
    "solid",
    "linked-data",
    "semantic-web",
    "category-theory",
    "composition",
    "federation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interego/interego.git"
  },
  "homepage": "https://interego.dev/spec/interego-1.0.html",
  "bugs": {
    "url": "https://github.com/interego/interego/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.81",
    "@anthropic-ai/sdk": "^0.80.0",
    "@comunica/query-sparql": "^5.1.3",
    "@huggingface/transformers": "^3.8.1",
    "@noble/hashes": "^2.0.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "multiformats": "^13.4.2",
    "pdf-parse": "^2.4.5",
    "siwe": "^3.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
}
