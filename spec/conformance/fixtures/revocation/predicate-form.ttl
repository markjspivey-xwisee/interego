@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#> .
@prefix ex:   <https://conformance.interego.example/ns#> .
@prefix test: <https://conformance.interego.example/test#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Conformance fixture: Proposal B (revokedIf predicate on SemioticFacet)
# Scenario: identical semantics to facet-form.ttl, different shape.
# Migration between the two forms is a blank-node rewrite:
#   move [ ... ] from iep:revokedBy (Proposal A, under RevocationFacet)
#     to iep:revokedIf (Proposal B, under SemioticFacet), or vice versa.

<test:predicate-form>
    a iep:ContextDescriptor ;
    iep:describes <test:graph:predicate-form-claim> ;

    iep:hasFacet [
        a iep:TemporalFacet ;
        iep:validFrom "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:ProvenanceFacet ;
        iep:generatedAtTime "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:AgentFacet ;
        iep:agentRole iep:Author
    ] ;

    iep:hasFacet [
        a iep:AccessControlFacet
    ] ;

    iep:hasFacet [
        a iep:SemioticFacet ;
        iep:modalStatus iep:Asserted ;
        iep:groundTruth true ;
        iep:epistemicConfidence "0.85"^^xsd:double ;
        # Proposal B: predicate directly on SemioticFacet
        iep:revokedIf [
            a iep:RevocationCondition ;
            iep:successorQuery """
                PREFIX ex: <https://conformance.interego.example/ns#>
                ASK WHERE {
                    GRAPH ?g { ?s ex:supersedes <test:graph:predicate-form-claim> . }
                }
            """ ;
            iep:evaluationScope iep:KnownFederation ;
            iep:onRevocation iep:MarkInvalid
        ]
    ] ;

    iep:hasFacet [
        a iep:TrustFacet ;
        iep:trustLevel iep:SelfAsserted
    ] ;

    iep:hasFacet [
        a iep:FederationFacet
    ] .
