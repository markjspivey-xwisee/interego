@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#> .
@prefix ex:   <https://conformance.interego.example/ns#> .
@prefix test: <https://conformance.interego.example/test#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Conformance fixture: self-reference in successor query (malformed)
# Scenario: the successor query's text contains the enclosing
# descriptor's own graph IRI — the graph is trying to revoke itself
# by its own existence, which is a bootstrap paradox.
#
# Expected: iep:RevocationConditionNoSelfReferenceShape fires. The
# entire revocation condition MUST be rejected by any conforming
# implementation that supports this extension. The rest of the
# descriptor remains valid.

<test:self-reference-violation>
    a iep:ContextDescriptor ;
    iep:describes <test:graph:self-ref-claim> ;

    iep:hasFacet [
        a iep:TemporalFacet ;
        iep:validFrom "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:ProvenanceFacet ;
        iep:generatedAtTime "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:AgentFacet ;
        iep:agentRole iep:Author
    ] ;

    iep:hasFacet [
        a iep:AccessControlFacet
    ] ;

    iep:hasFacet [
        a iep:SemioticFacet ;
        iep:modalStatus iep:Asserted ;
        iep:groundTruth true ;
        # MALFORMED: query references the enclosing claim's own graph IRI
        iep:revokedIf [
            a iep:RevocationCondition ;
            iep:successorQuery """
                PREFIX ex: <https://conformance.interego.example/ns#>
                ASK WHERE {
                    GRAPH <test:graph:self-ref-claim> { ?s ?p ?o . }
                }
            """ ;
            iep:evaluationScope iep:LocalPod ;
            iep:onRevocation iep:MarkInvalid
        ]
    ] ;

    iep:hasFacet [
        a iep:TrustFacet ;
        iep:trustLevel iep:SelfAsserted
    ] ;

    iep:hasFacet [
        a iep:FederationFacet
    ] .
