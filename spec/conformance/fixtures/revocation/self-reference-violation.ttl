@prefix cg:   <https://markjspivey-xwisee.github.io/interego/ns/cg#> .
@prefix ex:   <https://conformance.interego.example/ns#> .
@prefix test: <https://conformance.interego.example/test#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Conformance fixture: self-reference in successor query (malformed)
# Scenario: the successor query's text contains the enclosing
# descriptor's own graph IRI — the graph is trying to revoke itself
# by its own existence, which is a bootstrap paradox.
#
# Expected: cg:RevocationConditionNoSelfReferenceShape fires. The
# entire revocation condition MUST be rejected by any conforming
# implementation that supports this extension. The rest of the
# descriptor remains valid.

<test:self-reference-violation>
    a cg:ContextDescriptor ;
    cg:describes <test:graph:self-ref-claim> ;

    cg:hasFacet [
        a cg:TemporalFacet ;
        cg:validFrom "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    cg:hasFacet [
        a cg:ProvenanceFacet ;
        cg:generatedAtTime "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    cg:hasFacet [
        a cg:AgentFacet ;
        cg:agentRole cg:Author
    ] ;

    cg:hasFacet [
        a cg:AccessControlFacet
    ] ;

    cg:hasFacet [
        a cg:SemioticFacet ;
        cg:modalStatus cg:Asserted ;
        cg:groundTruth true ;
        # MALFORMED: query references the enclosing claim's own graph IRI
        cg:revokedIf [
            a cg:RevocationCondition ;
            cg:successorQuery """
                PREFIX ex: <https://conformance.interego.example/ns#>
                ASK WHERE {
                    GRAPH <test:graph:self-ref-claim> { ?s ?p ?o . }
                }
            """ ;
            cg:evaluationScope cg:LocalPod ;
            cg:onRevocation cg:MarkInvalid
        ]
    ] ;

    cg:hasFacet [
        a cg:TrustFacet ;
        cg:trustLevel cg:SelfAsserted
    ] ;

    cg:hasFacet [
        a cg:FederationFacet
    ] .
