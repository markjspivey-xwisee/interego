@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#> .
@prefix ex:   <https://conformance.interego.example/ns#> .
@prefix test: <https://conformance.interego.example/test#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Conformance fixture: trigger graph that does NOT satisfy the
# successor query from facet-form.ttl / predicate-form.ttl.
#
# Loaded alongside either proposal's fixture, the revocation evaluator
# MUST NOT revoke the original claim. Its effective groundTruth remains
# true (Asserted).
#
# Negative-path test for the "no silent false positives" property:
# a revocation-aware implementation that reports hits where none
# exist is buggy in both directions.

<test:trigger-misses>
    a iep:ContextDescriptor ;
    iep:describes <test:graph:trigger-misses-content> ;

    iep:hasFacet [
        a iep:TemporalFacet ;
        iep:validFrom "2026-04-15T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:ProvenanceFacet ;
        iep:generatedAtTime "2026-04-15T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:AgentFacet ;
        iep:agentRole iep:Author
    ] ;

    iep:hasFacet [
        a iep:AccessControlFacet
    ] ;

    iep:hasFacet [
        a iep:SemioticFacet ;
        iep:modalStatus iep:Asserted ;
        iep:groundTruth true ;
        iep:epistemicConfidence "0.95"^^xsd:double
    ] ;

    iep:hasFacet [
        a iep:TrustFacet ;
        iep:trustLevel iep:SelfAsserted
    ] ;

    iep:hasFacet [
        a iep:FederationFacet
    ] .

# Content graph: unrelated predicate; does NOT match ex:supersedes.

<test:graph:trigger-misses-content> {
    <test:unrelated-claim>
        ex:annotates <test:graph:facet-form-claim> .
}
