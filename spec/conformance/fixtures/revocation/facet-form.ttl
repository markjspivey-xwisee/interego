@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#> .
@prefix ex:   <https://conformance.interego.example/ns#> .
@prefix test: <https://conformance.interego.example/test#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# Conformance fixture: Proposal A (seventh-facet revocation)
# Scenario: a descriptor that declares its own revocation condition as a
# separate 7th facet. The condition's successor query asks whether any
# graph in the federation supersedes this claim; if so, mark invalid.

<test:facet-form>
    a iep:ContextDescriptor ;
    iep:describes <test:graph:facet-form-claim> ;

    iep:hasFacet [
        a iep:TemporalFacet ;
        iep:validFrom "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:ProvenanceFacet ;
        iep:generatedAtTime "2026-04-01T00:00:00Z"^^xsd:dateTime
    ] ;

    iep:hasFacet [
        a iep:AgentFacet ;
        iep:agentRole iep:Author
    ] ;

    iep:hasFacet [
        a iep:AccessControlFacet
    ] ;

    iep:hasFacet [
        a iep:SemioticFacet ;
        iep:modalStatus iep:Asserted ;
        iep:groundTruth true ;
        iep:epistemicConfidence "0.85"^^xsd:double
    ] ;

    iep:hasFacet [
        a iep:TrustFacet ;
        iep:trustLevel iep:SelfAsserted
    ] ;

    iep:hasFacet [
        a iep:FederationFacet
    ] ;

    # Proposal A: seventh facet
    iep:hasFacet [
        a iep:RevocationFacet ;
        iep:revokedBy [
            a iep:RevocationCondition ;
            iep:successorQuery """
                PREFIX ex: <https://conformance.interego.example/ns#>
                ASK WHERE {
                    GRAPH ?g { ?s ex:supersedes <test:graph:facet-form-claim> . }
                }
            """ ;
            iep:evaluationScope iep:KnownFederation ;
            iep:onRevocation iep:MarkInvalid
        ]
    ] .
