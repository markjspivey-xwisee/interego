{
  "@context": {
    "@version": 1.1,
    "amep": "https://markjspivey-xwisee.github.io/affordant-memory-protocol/0.1#",
    "iep": "https://markjspivey-xwisee.github.io/interego/ns/iep#",
    "ieh": "https://markjspivey-xwisee.github.io/interego/ns/harness#",
    "ie": "https://markjspivey-xwisee.github.io/interego/ns/interego#",
    "pgsl": "https://markjspivey-xwisee.github.io/interego/ns/pgsl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "prov": "http://www.w3.org/ns/prov#",
    "dct": "http://purl.org/dc/terms/",
    "hydra": "http://www.w3.org/ns/hydra/core#",
    "sh": "http://www.w3.org/ns/shacl#",
    "foaf": "http://xmlns.com/foaf/0.1/",

    "profile": { "@id": "dct:conformsTo", "@type": "@id" },
    "actor": { "@id": "amep:actor", "@type": "@id" },
    "displayName": "foaf:name",
    "act": { "@id": "amep:act", "@type": "@id" },
    "receipts": { "@id": "amep:receipt", "@container": "@set" },
    "memory": { "@id": "amep:memory", "@type": "@id" },
    "head": { "@id": "amep:head", "@type": "@id" },
    "actType": { "@id": "amep:actType", "@type": "@id" },
    "createdAt": { "@id": "prov:startedAtTime", "@type": "xsd:dateTime" },
    "generatedAt": { "@id": "prov:generatedAtTime", "@type": "xsd:dateTime" },
    "attributedTo": { "@id": "prov:wasAttributedTo", "@type": "@id" },
    "expectedHead": { "@id": "amep:expectedHead", "@type": "@id" },
    "previousHead": { "@id": "amep:previousHead", "@type": "@id" },
    "resultHead": { "@id": "amep:resultHead", "@type": "@id" },
    "parentHead": { "@id": "amep:parentHead", "@type": "@id" },
    "branch": "amep:branch",
    "operands": { "@id": "amep:operand", "@type": "@id", "@container": "@set" },
    "acceptedAct": { "@id": "amep:acceptedAct", "@type": "@id" },
    "challengedAct": { "@id": "amep:challengedAct", "@type": "@id" },
    "receiptFor": { "@id": "amep:receiptFor", "@type": "@id" },
    "outcome": { "@id": "amep:outcome", "@type": "@id" },
    "validationReport": { "@id": "amep:validationReport", "@type": "@id" },
    "conforms": { "@id": "sh:conforms", "@type": "xsd:boolean" },

    "memoryKind": { "@id": "amep:memoryKind", "@type": "@id" },
    "governanceStatus": { "@id": "amep:governanceStatus", "@type": "@id" },
    "integrityStatus": { "@id": "amep:integrityStatus", "@type": "@id" },
    "conformanceStatus": { "@id": "amep:conformanceStatus", "@type": "@id" },
    "epistemicStatus": { "@id": "amep:epistemicStatus", "@type": "@id" },
    "semantic": { "@id": "amep:semantic", "@type": "@id" },
    "semanticCid": "amep:semanticCid",
    "representationTag": "amep:representationTag",
    "envelopeCid": "amep:envelopeCid",
    "body": "rdf:value",
    "reuses": { "@id": "amep:reuses", "@type": "@id" },
    "reusedSemanticCid": "amep:reusedSemanticCid",
    "interpretation": "amep:interpretation",

    "affordances": { "@id": "iep:affordance", "@container": "@set" },
    "action": { "@id": "iep:action", "@type": "@id" },
    "target": { "@id": "hydra:target", "@type": "@id" },
    "method": "hydra:method",
    "inputShape": { "@id": "amep:inputShape", "@type": "@id" },
    "effect": "amep:effect",
    "proof": { "@id": "iep:proof", "@type": "@id" },
    "proofValue": "iep:proofValue",
    "verificationMethod": { "@id": "iep:verificationMethod", "@type": "@id" },
    "created": { "@id": "iep:created", "@type": "xsd:dateTime" }
  }
}
