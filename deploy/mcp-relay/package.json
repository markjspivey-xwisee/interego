{
  "name": "@interego/mcp-relay",
  "version": "0.3.0",
  "description": "Cloud-hosted MCP relay — HTTP/SSE bridge for remote AI agents to access Interego tools",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "test": "tsx tests/dpop.test.ts && tsx tests/federation-persistence.test.ts && tsx tests/oauth-token-persistence.test.ts && tsx tests/pgsl-shim-kernel-fusion.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@interego/compliance": "*",
    "@interego/core": "*",
    "@interego/ops": "*",
    "@interego/pgsl": "*",
    "@interego/privacy": "*",
    "@interego/security-txt": "*",
    "@interego/solid": "*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@playwright/test": "^1.49.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
