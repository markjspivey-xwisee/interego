{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["server.ts", "oauth-provider.ts", "oauth-client-store.ts", "oauth-token-store.ts", "federation-store.ts", "dpop.ts", "cors-allowlist.ts"],
  "exclude": ["node_modules", "dist"]
}
