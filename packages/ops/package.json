{
  "name": "@interego/ops",
  "version": "0.2.0",
  "description": "SOC 2 operational evidence event builders (deploys, access changes, wallet rotations, incidents, quarterly reviews) emitting @interego/core descriptors via @interego/compliance frameworks.",
  "author": "Mark Spivey",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "src/", "README.md"],
  "scripts": { "build": "tsc", "watch": "tsc --watch", "clean": "rm -rf dist/" },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "@interego/core": "*",
    "@interego/compliance": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
