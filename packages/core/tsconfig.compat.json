// Two-pass build: the substrate (src/**/* minus compat.ts) compiles
// against intra-package files only. The compat shim re-exports from
// the sibling @interego/* packages, so it needs those packages built
// + symlinked first. This config compiles only compat.ts after the
// leaves are in place.
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/compat.ts"],
  "exclude": ["node_modules", "dist"]
}
