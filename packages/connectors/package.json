{
  "name": "@interego/connectors",
  "version": "0.2.0",
  "description": "Notion / Slack / Web source connectors that ingest into @interego/core descriptors. Particular external-source binding; uses @interego/extractors for content parsing.",
  "author": "Mark Spivey",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "src/", "README.md"],
  "scripts": { "build": "tsc", "watch": "tsc --watch", "clean": "rm -rf dist/" },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "@interego/core": "*",
    "@interego/extractors": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
