{
  "name": "@interego/openclaw-memory",
  "version": "0.1.0",
  "description": "OpenClaw memory plugin — pod-rooted typed memory via Interego primitives.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@interego/core": "*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0"
}
