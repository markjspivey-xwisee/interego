# quickstart/.env — copy to quickstart/.env and fill in.
#
# REQUIRED
# --------

# Pod URL the OWM bridge writes to. Two valid choices:
#
# 1. Hosted reference pod (no setup, fastest evaluation):
#    OWM_POD_URL=https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/u-pk-<your-id>/
#
# 2. Self-hosted Solid pod (your own infrastructure):
#    OWM_POD_URL=https://your-pod.example.com/me/
#
# The bridge uses a sub-container under this URL named context-graphs/.
OWM_POD_URL=

# OPTIONAL
# --------

# Org DID for OWM descriptors (default did:web:org.example).
OWM_ORG_DID=did:web:org.example

# Personal-bridge wallet — leave blank to autogenerate on first boot.
# Set to a 0x-prefixed 32-byte hex string for stable identity across restarts.
BRIDGE_KEY=

# Persist the personal-bridge's relay events to disk (1=yes, 0=in-memory).
BRIDGE_PERSIST=1

# External relays (comma-separated wss:// or ws:// URLs) the personal-bridge
# mirrors events to. Leave blank for fully local — sharing then happens via
# per-publish share_with calls at the protocol layer.
EXTERNAL_RELAYS=

# Inbound author allow-list. Leave blank for outbound-only mode (bridge does
# not subscribe to any external authors). To receive encrypted shares from a
# specific peer, set their wallet pubkey here (comma-separated for multiple).
INBOUND_AUTHORS=
