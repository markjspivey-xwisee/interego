  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/pgsl" },
    { "path": "./packages/solid" },
    { "path": "./packages/abac" },
    { "path": "./packages/compliance" },
    { "path": "./packages/connectors" },
    { "path": "./packages/constitutional" },
    { "path": "./packages/extractors" },
    { "path": "./packages/ops" },
    { "path": "./packages/p2p" },
    { "path": "./packages/passport" },
    { "path": "./packages/privacy" },
    { "path": "./packages/registry" },
    { "path": "./packages/security-txt" },
    { "path": "./packages/skills" },
    { "path": "./packages/transactions" }
  ]
}
