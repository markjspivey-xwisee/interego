<https://example.foxximediums.com/pkg/_69JeglEuzyv/narration/story_content%2F6Yj2OVM5BXp_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT16S"^^xsd:duration ;
