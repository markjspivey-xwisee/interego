    prov:wasDerivedFrom <https://example.foxximediums.com/pkg/_69JeglEuzyv> .

<https://example.foxximediums.com/pkg/_69JeglEuzyv/narration/story_content%2F6O98E7I3oiU_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT9S"^^xsd:duration ;
    cnt:chars "Click on each photo to learn about some control objectives for a fault ride through response. Click next when you have finished to continue to a lesson summary." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://example.foxximediums.com/pkg/_69JeglEuzyv/asset/story_content%2F6O98E7I3oiU_44100_48_0.mp3> .

