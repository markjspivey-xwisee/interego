    schema:identifier "Slide3" ;
    fxs:embedsAsset <https://example.foxximediums.com/pkg/_69JeglEuzyv/asset/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> ;
    fxs:embedsAsset <https://example.foxximediums.com/pkg/_69JeglEuzyv/asset/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> ;
