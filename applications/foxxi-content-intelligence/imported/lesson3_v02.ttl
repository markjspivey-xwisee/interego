    fxs:embedsAsset <https://example.foxximediums.com/pkg/_69JeglEuzyv/asset/story_content%2F6SypeIXvavu_44100_48_0.mp3> ;
    fxs:embedsAsset <https://example.foxximediums.com/pkg/_69JeglEuzyv/asset/story_content%2F5nckAIutyat_44100_48_0.mp3> ;
