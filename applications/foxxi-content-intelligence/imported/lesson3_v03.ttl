<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6XoiU1qYPis_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/6XoiU1qYPis_44100_48_0.mp3" ;
    schema:duration "PT28S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F6XoiU1qYPis_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT28S"^^xsd:duration ;
    cnt:chars "It's important for transmission operations personnel to understand how IBR's synchronize to the grid and manage current voltage and power flows. IBR's use advanced electronics to control how they interact with the grid. In the last lesson, we focused on how to produce the desired voltage given a reference voltage. In this lesson, we'll focus on how the control system for the inverter produces the desired voltage set point based on the commands from the base level controller." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6XoiU1qYPis_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5dLzuRNCmmT_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/5dLzuRNCmmT_44100_48_0.mp3" ;
    schema:duration "PT9S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F5dLzuRNCmmT_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT9S"^^xsd:duration ;
    cnt:chars "Upon completion of this lesson, you should be able to describe key aspects of the various IBR control system options and be able to meet the learning objectives shown." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5dLzuRNCmmT_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/slide/5zBRyvxOwou> a fxs:Slide ;
    dcterms:title "Inverter Operating Principles" ;
    fxs:identifiedBy "5zBRyvxOwou" ;
    fxs:sequenceIndex 2 ;
    fxs:fileLocator "package!/html5/data/js/5zBRyvxOwou.js" ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/res/__69JeglEuzyv_RES> ;
    schema:identifier "Slide3" ;
    fxs:embedsAsset <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> ;
    fxs:embedsAsset <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> ;
    fxs:hasNarration <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> ;
    fxs:hasNarration <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> ;
    fxs:extractedTextCorpus "Rectangle 3; Rectangle 5; Rectangle 4; Rectangle 1; Down Arrow 1; Click each equation to see what it represents; Rectangle 13; Down Arrow 2; Rectangle 12; Rectangle 2" .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/6qbFcOmxbpl_44100_48_0.mp3" ;
    schema:duration "PT17S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT17S"^^xsd:duration ;
    cnt:chars "To begin, let's review a few foundational inverter operating principles. A present day inverter connects to a network grid. The inverter and the network are different technologies, but the inverter control must follow the grid voltage, so that the inverter and grid are synchronized." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6qbFcOmxbpl_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/5pUWbRqZNS6_44100_48_0.mp3" ;
    schema:duration "PT45S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT45S"^^xsd:duration ;
    cnt:chars "As discussed in lesson two, the plant controller provides the set points for active and reactive power. The inverter must quickly and accurately estimate the frequency and the phase angle of grid voltage. This is achieved using a phase-locked loop or PLL. In addition, when the grid voltage changes, the inverter control needs to respond quickly to that change, accurately controlling its terminal current to generate the voltage reference. Simply put, the current injected by the inverter, determined by complex power divided by voltage, needs to match the current drawn by the network, voltage divided by impedance, to maintain the stable grid operation. Click each equation at the bottom of the page for additional information. Click next to continue." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5pUWbRqZNS6_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/slide/6eVptVTR2Lx> a fxs:Slide ;
    dcterms:title "Current Control Overview" ;
    fxs:identifiedBy "6eVptVTR2Lx" ;
    fxs:sequenceIndex 3 ;
    fxs:fileLocator "package!/html5/data/js/6eVptVTR2Lx.js" ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/res/__69JeglEuzyv_RES> ;
    schema:identifier "Slide4" ;
    fxs:embedsAsset <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F68UQ9jgrgX0_44100_48_0.mp3> ;
    fxs:embedsAsset <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6llp0vzR9dL_44100_48_0.mp3> ;
    fxs:hasNarration <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F68UQ9jgrgX0_44100_48_0.mp3> ;
    fxs:hasNarration <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F6llp0vzR9dL_44100_48_0.mp3> ;
    fxs:extractedTextCorpus "Rectangle 3; Control output current of the inverter:; Using measured and transformed current, i; Up Arrow 1; Rectangle 4; Inverter Control Objective; Rectangle 1; Using measured and transformed voltage, Vt; Image 38.emf; Inverter Control Objective\\nControl output current of the inverter: \\nUsing measured and transformed current, i\\nUsing measured and transformed voltage, Vt; Rectangle 2; Up Arrow 2" .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F68UQ9jgrgX0_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/68UQ9jgrgX0_44100_48_0.mp3" ;
    schema:duration "PT15S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F68UQ9jgrgX0_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT15S"^^xsd:duration ;
    cnt:chars "The objective of Inverter Control is to control the output current of the inverter by using the measured and transformed current and measured and transformed voltage as inputs. The output is the voltage reference or modulating signal for the PWM scheme." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F68UQ9jgrgX0_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6llp0vzR9dL_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/6llp0vzR9dL_44100_48_0.mp3" ;
    schema:duration "PT28S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F6llp0vzR9dL_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT28S"^^xsd:duration ;
    cnt:chars "The inverter control achieves the subjective through a nested loop structure. You learned about this flow in lesson 2, but let's review. The plant controller provides the desired active and reactive power set points to the inverter control. Sensors measure the voltage. The outer loop provides the reference currents which the inner loop uses to generate the reference voltage. This voltage reference is processed by the PWM scheme to generate the system reference voltage E." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F6llp0vzR9dL_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/slide/5q1PTTjK3aS> a fxs:Slide ;
    dcterms:title "Power and Voltage Control Overview" ;
    fxs:identifiedBy "5q1PTTjK3aS" ;
    fxs:sequenceIndex 4 ;
    fxs:fileLocator "package!/html5/data/js/5q1PTTjK3aS.js" ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/res/__69JeglEuzyv_RES> ;
    schema:identifier "Slide5" ;
    fxs:embedsAsset <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5x2cQjOSedu_44100_48_0.mp3> ;
    fxs:hasNarration <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F5x2cQjOSedu_44100_48_0.mp3> ;
    fxs:extractedTextCorpus "Rectangle 3; Rectangle 5; Rectangle 4; Power Control; Rectangle 6; Rectangle 1; Voltage Control; Rectangle 2" .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5x2cQjOSedu_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/5x2cQjOSedu_44100_48_0.mp3" ;
    schema:duration "PT21S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/narration/story_content%2F5x2cQjOSedu_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT21S"^^xsd:duration ;
    cnt:chars "Now that we've discussed current control, let's discuss power and voltage control. Power control is dependent on the primary power source. The inverter controls DC voltage while terminal voltage depends on both the inverter and how the system is reacting to it. Click next to look in more depth at active and reactive power control." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson3/asset/story_content%2F5x2cQjOSedu_44100_48_0.mp3> .

