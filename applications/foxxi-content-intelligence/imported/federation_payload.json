        "id": "hcp-overview",
        "title": "Handicap Overview",
        "sequence_index": 0,
        "concept_ids": ["handicap", "score", "stroke-index"],
        "transcript_combined": "A handicap is a numerical measure of a golfer's potential ability. It is calculated from recent scores adjusted by the course's stroke index. Lower handicaps indicate stronger players."
      },
      {
        "id": "hcp-calc-score",
        "title": "Calculating Your Score",
        "sequence_index": 1,
        "concept_ids": ["score"],
        "transcript_combined": "Your gross score is the total number of strokes taken across the round. Net score subtracts your handicap from the gross score."
      },
      {
        "id": "hcp-calc-handi",
        "title": "Handicap Calculation",
        "sequence_index": 2,
        "concept_ids": ["handicap", "reactive-handicap", "golf-voltage"],
        "transcript_combined": "Handicap is the component of the golf's output current that contributes to voltage regulation rather than active power transfer. The reactive handicap component is derived from your score differentials over recent rounds."
      },
      {
        "id": "hcp-example",
        "title": "Worked Example",
        "sequence_index": 3,
        "concept_ids": ["handicap", "control-output"],
        "transcript_combined": "Suppose your last five score differentials are 12, 14, 11, 13, 15. The control output current — your handicap — is the average of the lowest of these adjusted by the course slope."
      }
