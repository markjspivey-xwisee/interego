    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F6c6h3gw7imQ_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F6cnvKgiVmjD_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/6cnvKgiVmjD_44100_48_0.mp3" ;
    schema:duration "PT13S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/narration/story_content%2F6cnvKgiVmjD_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT13S"^^xsd:duration ;
    cnt:chars "You learned about some features of inverter and plant controls, and how the individual inverter and plant level controls schemes operate at different speeds, with the individual inverter controls acting faster." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F6cnvKgiVmjD_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F6Z8paIPGGjc_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/6Z8paIPGGjc_44100_48_0.mp3" ;
    schema:duration "PT14S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/narration/story_content%2F6Z8paIPGGjc_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT14S"^^xsd:duration ;
    cnt:chars "You then reviewed power electronic concepts pertinent to IBR integration with traditional power resources. These included switches, voltage and current sourced converters, pulse width modulation and output filters." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F6Z8paIPGGjc_44100_48_0.mp3> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F5b3CG0SdgY6_44100_48_0.mp3> a fxs:Asset ;
    dcterms:format "audio/mpeg" ;
    fxs:fileLocator "package!/story_content/5b3CG0SdgY6_44100_48_0.mp3" ;
    schema:duration "PT11S"^^xsd:duration ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2> .

<https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/narration/story_content%2F5b3CG0SdgY6_44100_48_0.mp3> a fxs:NarrationTranscript ;
    dcterms:language "en" ;
    schema:duration "PT11S"^^xsd:duration ;
    cnt:chars "You should now be able to describe how different control layers interconnect and coordinate across time scales and describe the differences between voltage and current sourced converters." ;
    fxs:transcribedBy <https://github.com/SYSTRAN/faster-whisper#tiny.en> ;
    prov:wasDerivedFrom <https://interego-css.livelysky-8b81abb0.eastus.azurecontainerapps.io/markj/courses/lesson2/asset/story_content%2F5b3CG0SdgY6_44100_48_0.mp3> .

