// Workspace bridge tsconfig — resolves @interego/core via the
// workspace symlink in node_modules. The old `paths` override pointed
// at the legacy `src/` monolith (now packages/core/src) and is no
// longer needed.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "../../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "server.ts",
    "../affordances.ts",
    "../src/**/*.ts",
    "../../_shared/affordance-mcp/**/*.ts",
    "../../_shared/vertical-bridge/**/*.ts",
    "../../_shared/aggregate-privacy/**/*.ts",
    "../../_shared/vc-jwt/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "../dashboard-app"]
}
