{
  "name": "@interego/mcp",
  "version": "0.4.1",
  "description": "MCP server for Interego — gives AI coding agents the ability to publish, discover, and compose context-annotated knowledge graphs through Solid pods",
  "author": "Interego",
  "license": "CC-BY-4.0",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "context-graphs-mcp": "./dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@interego/core": "^0.2.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "context-graphs",
    "rdf",
    "solid",
    "knowledge-graph",
    "ai-agent",
    "claude",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markjspivey-xwisee/interego.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/markjspivey-xwisee/interego/tree/master/mcp-server",
  "bugs": {
    "url": "https://github.com/markjspivey-xwisee/interego/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
