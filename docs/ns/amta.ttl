@prefix amta: <https://markjspivey-xwisee.github.io/interego/ns/amta#> .
@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#> .
@prefix ieh:  <https://markjspivey-xwisee.github.io/interego/ns/harness#> .
@prefix pgsl: <https://markjspivey-xwisee.github.io/interego/ns/pgsl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ══════════════════════════════════════════════════════════════
#  AMTA — Agent-Mediated Trust Attestation
# ══════════════════════════════════════════════════════════════
#
#  AMTA models the process by which one agent attests to the
#  trustworthiness of another agent's claims — not as a single
#  yes/no boolean, but as a multi-dimensional attestation with
#  explicit axes:
#
#    - Competence    (can the agent produce correct claims?)
#    - Honesty       (does the agent report their claims faithfully?)
#    - Relevance     (is the agent's expertise germane to the claim?)
#    - Recency       (is the attestation still current?)
#
#  Each axis is an ordinal rating; the combined attestation is a
#  vector rather than a scalar. This lets trust policies reason
#  compositionally — e.g. "require competence > 0.8 AND recency <
#  30 days" as an ODRL constraint.
#
#  AMTA attestations are stored as iep:TrustFacet specializations
#  on descriptors. An agent's reputation is the distribution of
#  attestations it has received over time.
#
#  Stub ontology; expand as AMTA's spec formalizes.

<https://markjspivey-xwisee.github.io/interego/ns/amta>
    a owl:Ontology ;
    dct:title "AMTA — Agent-Mediated Trust Attestation" ;
    dct:description "Multi-dimensional trust attestations: competence, honesty, relevance, recency. Each axis is rated ordinally; combined attestation is a vector usable in policy decisions. Stored as iep:TrustFacet specializations." ;
    vann:preferredNamespacePrefix "amta" ;
    vann:preferredNamespaceUri "https://markjspivey-xwisee.github.io/interego/ns/amta#" ;
    owl:imports <https://markjspivey-xwisee.github.io/interego/ns/iep> .

amta:Attestation a owl:Class ;
    rdfs:subClassOf iep:TrustFacet ;
    rdfs:label "AMTA Attestation" ;
    rdfs:comment "A multi-dimensional trust attestation by one agent (the attestor) about another agent or claim (the subject). Subclass of iep:TrustFacet; inherits trust-level + issuer semantics and adds per-axis ratings." .

amta:CompetenceRating a owl:Class ;
    rdfs:label "Competence Rating" ;
    rdfs:comment "Rating of the subject's ability to produce correct claims in the relevant domain. Ordinal 0.0 - 1.0. A lens on iep:SemioticFacet.epistemicConfidence filtered to the attestor's domain." ;
    rdfs:subClassOf iep:SemioticFacet .

amta:HonestyRating a owl:Class ;
    rdfs:label "Honesty Rating" ;
    rdfs:comment "Rating of the subject's faithful reporting. Specialization of iep:TrustFacet for a per-axis honesty signal." ;
    rdfs:subClassOf iep:TrustFacet .

amta:RelevanceRating a owl:Class ;
    rdfs:label "Relevance Rating" ;
    rdfs:comment "Rating of whether the subject's expertise is germane to the specific claim being attested." ;
    rdfs:subClassOf iep:TrustFacet .

amta:RecencyRating a owl:Class ;
    rdfs:label "Recency Rating" ;
    rdfs:comment "Rating derived from time-since-attestation. Constructed from iep:TemporalFacet.validFrom + an attestation's provenance timestamp." ;
    iep:constructedFrom ( iep:TemporalFacet iep:TrustFacet ) .

amta:Reputation a owl:Class ;
    rdfs:label "Reputation" ;
    rdfs:comment "The aggregate of attestations an agent has received. Constructed at runtime from a set of amta:Attestation descriptors via statistical aggregation; see examples/reputation-aggregator.mjs for a reference realization." ;
    iep:constructedFrom ( amta:Attestation ) .

amta:attestor a owl:ObjectProperty ;
    rdfs:label "attestor" ;
    rdfs:domain amta:Attestation ;
    rdfs:range iep:AuthorizedAgent .

amta:subject a owl:ObjectProperty ;
    rdfs:label "subject" ;
    rdfs:domain amta:Attestation .

amta:competence a owl:DatatypeProperty ;
    rdfs:label "competence" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:double .

amta:honesty a owl:DatatypeProperty ;
    rdfs:label "honesty" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:double .

amta:relevance a owl:DatatypeProperty ;
    rdfs:label "relevance" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:double .

amta:recency a owl:DatatypeProperty ;
    rdfs:label "recency" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:double .

amta:attestedAt a owl:DatatypeProperty ;
    rdfs:label "attested at" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:dateTime .

# ── Capability / execution-grounded attestation predicates ─────
#
# Beyond the per-axis numeric ratings above, an attestation may be
# bound to a specific capability (tool / teaching package), tagged
# with the trust axis it rates, grounded in the execution evidence
# that justifies it, and carry a single normalized rating value.

amta:attestsTo a owl:ObjectProperty ;
    rdfs:label "attests to" ;
    rdfs:domain amta:Attestation ;
    rdfs:comment "The capability the attestation concerns — typically a tool, teaching package, or other artifact IRI. The attestation rates the subject's competence/honesty/etc. with respect to this capability." .

amta:axis a owl:ObjectProperty ;
    rdfs:label "axis" ;
    rdfs:domain amta:Attestation ;
    rdfs:comment "The trust axis this attestation rates (e.g. correctness, efficiency, safety, generality). Lets a single attestation declare which dimension its amta:rating applies to, rather than carrying every per-axis property." .

amta:fromExecution a owl:ObjectProperty ;
    rdfs:label "from execution" ;
    rdfs:domain amta:Attestation ;
    rdfs:comment "The execution-evidence descriptor that grounds this attestation — the recorded tool execution / verified transfer the rating was derived from. Makes the attestation auditable rather than self-asserted." .

amta:rating a owl:DatatypeProperty ;
    rdfs:label "rating" ;
    rdfs:domain amta:Attestation ;
    rdfs:range xsd:double ;
    rdfs:comment "A single normalized rating value (0.0 - 1.0) for the axis named by amta:axis. Used when an attestation rates one axis at a time rather than carrying the full per-axis vector." .

# ── Alignments ────────────────────────────────────────────────

amta:Attestation rdfs:seeAlso iep:TrustFacet , ieh:PolicyDecision ;
    rdfs:comment "AMTA attestations become inputs to ieh:PolicyDecision evaluations via ODRL constraints that reference per-axis ratings." .
