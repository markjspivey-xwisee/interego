iep:atomCount a owl:DatatypeProperty ; rdfs:label "atom count" ; rdfs:range xsd:nonNegativeInteger ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:fragmentCount a owl:DatatypeProperty ; rdfs:label "fragment count" ; rdfs:range xsd:nonNegativeInteger ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:chainId a owl:DatatypeProperty ; rdfs:label "chain id" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:description a owl:DatatypeProperty ; rdfs:label "description" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:timestamp a owl:DatatypeProperty ; rdfs:label "timestamp" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:tool a owl:DatatypeProperty ; rdfs:label "tool" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:success a owl:DatatypeProperty ; rdfs:label "success" ; rdfs:range xsd:boolean ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:errorMessage a owl:DatatypeProperty ; rdfs:label "error message" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:affordanceRel a owl:ObjectProperty ; rdfs:label "affordance relation" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
