iep:mappingType a owl:ObjectProperty ; rdfs:label "mapping type" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:targetVocabulary a owl:ObjectProperty ; rdfs:label "target vocabulary" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
