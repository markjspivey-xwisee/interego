iep:exposedEntity a owl:ObjectProperty ; rdfs:label "exposed entity" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:hiddenEntity a owl:ObjectProperty ; rdfs:label "hidden entity" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causalConfidence a owl:DatatypeProperty ; rdfs:label "causal confidence" ; rdfs:range xsd:double ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causalRole a owl:DatatypeProperty ; rdfs:label "causal role" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causalEdge a owl:ObjectProperty ; rdfs:label "causal edge" ; rdfs:range iep:CausalEdge ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causalVariable a owl:ObjectProperty ; rdfs:label "causal variable" ; rdfs:range iep:CausalVariable ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causalModel a owl:ObjectProperty ; rdfs:label "causal model" ; rdfs:range iep:StructuralCausalModel ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:counterfactualQuery a owl:DatatypeProperty ; rdfs:label "counterfactual query" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:counterfactualTarget a owl:ObjectProperty ; rdfs:label "counterfactual target" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:counterfactualEvidence a owl:ObjectProperty ; rdfs:label "counterfactual evidence" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
