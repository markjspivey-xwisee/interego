iep:selectedAffordance a owl:ObjectProperty ; rdfs:label "selected affordance" ; rdfs:range iep:Affordance ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:capability a owl:ObjectProperty ; rdfs:label "capability" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:endpoint a owl:ObjectProperty ; rdfs:label "endpoint" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:latticeRoot a owl:ObjectProperty ; rdfs:label "lattice root" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
