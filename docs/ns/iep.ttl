iep:parentIntervention a owl:ObjectProperty ; rdfs:label "parent intervention" ; rdfs:range iep:Intervention ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:outcome a owl:ObjectProperty ; rdfs:label "outcome" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:selective a owl:DatatypeProperty ; rdfs:label "selective" ; rdfs:range xsd:boolean ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.

# ══════════════════════════════════════════════════════════════
#  Revocation Extension (DRAFT — rival proposals A + B)
#
#  See spec/revocation.md for the prose specification. These terms
#  are declared with vs:term_status "testing" (W3C SemWeb Vocabulary
#  Status) to signal they are NOT YET adopted as protocol-normative.
#  An implementation MAY emit them; readers MAY consume them; neither
#  is required for v1.0 conformance.
#
#  Once one of Proposal A (7th facet) or Proposal B (predicate on
#  SemioticFacet) is ratified, the adopted terms move to
#  vs:term_status "stable" and the rival terms move to "archaic".
#  Until then, the shared RevocationCondition model is specified in
#  both proposals identically so migration is a blank-node rewrite.
# ══════════════════════════════════════════════════════════════

# ─── Shared RevocationCondition model (both proposals) ────────

iep:RevocationCondition a owl:Class ;
    rdfs:label "Revocation Condition" ;
    rdfs:comment "A declarative condition under which an asserted claim's effective groundTruth transitions to false. Consists of a successor query (SPARQL 1.1 ASK/SELECT), an evaluation scope, and an action to take when the query matches. Shared by Proposal A (RevocationFacet) and Proposal B (revokedIf predicate) so conditions are portable between the two." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:successorQuery a owl:DatatypeProperty ;
    rdfs:label "successor query" ;
    rdfs:comment "SPARQL 1.1 ASK/SELECT/CONSTRUCT query evaluated over the scope declared by iep:evaluationScope. A non-empty result triggers the revocation action. MUST NOT reference the enclosing descriptor's own graph IRI (caught by iep:RevocationConditionNoSelfReferenceShape)." ;
    rdfs:domain iep:RevocationCondition ;
    rdfs:range xsd:string ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:evaluationScope a owl:ObjectProperty ;
    rdfs:label "evaluation scope" ;
    rdfs:comment "The federation scope over which the successor query is evaluated. One of iep:LocalPod, iep:KnownFederation, iep:WebFingerResolvable." ;
    rdfs:domain iep:RevocationCondition ;
    rdfs:range iep:RevocationScope ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:onRevocation a owl:ObjectProperty ;
    rdfs:label "on-revocation action" ;
    rdfs:comment "Action to take when the successor query matches. One of iep:MarkInvalid, iep:DowngradeToHypothetical, iep:RequireReconfirmation. Implementations MUST support iep:MarkInvalid; the others are RECOMMENDED." ;
    rdfs:domain iep:RevocationCondition ;
    rdfs:range iep:RevocationAction ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:revocationIssuer a owl:ObjectProperty ;
    rdfs:label "revocation issuer" ;
    rdfs:comment "The agent or principal that asserts this revocation condition. MAY differ from the enclosing descriptor's author (a regulator, auditor, or domain authority attaching a revocation policy to someone else's claim). When absent, the enclosing descriptor's author is assumed." ;
    rdfs:domain iep:RevocationCondition ;
    rdfs:range foaf:Agent ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Evaluation-scope closed vocabulary ───────────────────────

iep:RevocationScope a owl:Class ;
    rdfs:label "Revocation Scope" ;
    rdfs:comment "Closed vocabulary for the federation scope over which a revocation successor query is evaluated." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:LocalPod a iep:RevocationScope ;
    rdfs:label "Local Pod" ;
    rdfs:comment "Evaluate the successor query only against descriptors on the same pod that hosts the declaring descriptor. Cheapest; no federation calls." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:KnownFederation a iep:RevocationScope ;
    rdfs:label "Known Federation" ;
    rdfs:comment "Evaluate across every pod in the evaluating reader's known-pods registry. Readers MAY cache federation state; eventual consistency is acceptable." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:WebFingerResolvable a iep:RevocationScope ;
    rdfs:label "WebFinger Resolvable" ;
    rdfs:comment "Evaluate across any pod reachable from the query's cited handles via WebFinger (RFC 7033) or DID resolution. Strongest scope; highest latency." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Revocation-action closed vocabulary ──────────────────────

iep:RevocationAction a owl:Class ;
    rdfs:label "Revocation Action" ;
    rdfs:comment "Closed vocabulary for the effect of a triggered revocation condition on the enclosing descriptor's modal state." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:MarkInvalid a iep:RevocationAction ;
    rdfs:label "Mark Invalid" ;
    rdfs:comment "Effective groundTruth transitions to false. Modal status effectively becomes Counterfactual for readers performing currently-valid queries. This is the default and the only action MUST-supported by conforming implementations." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:DowngradeToHypothetical a iep:RevocationAction ;
    rdfs:label "Downgrade To Hypothetical" ;
    rdfs:comment "Modal status transitions to Hypothetical; groundTruth becomes undefined. Signals \"we're no longer sure either way.\"" ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:RequireReconfirmation a iep:RevocationAction ;
    rdfs:label "Require Reconfirmation" ;
    rdfs:comment "Modal status is preserved but the descriptor is flagged as requiring the original issuer (or a delegated authority) to re-sign before it may be used for downstream assertions. Useful for high-stakes claims where automatic invalidation would be too aggressive." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Proposal A — seventh-facet RevocationFacet ───────────────

iep:RevocationFacet a owl:Class ;
    rdfs:subClassOf iep:ContextFacet ;
    rdfs:label "Revocation Facet (Proposal A — draft)" ;
    rdfs:comment "DRAFT. An additional context-facet type carrying one or more RevocationConditions. Proposal A of the revocation extension spec (see spec/revocation.md). Enables discovery by facet_type=Revocation without inspecting other facets; supports revocation issuers that differ from the descriptor author. Relaxes the core-facet invariant to \"at least the seven core facets plus at most one RevocationFacet.\" Rival: Proposal B (iep:revokedIf predicate on SemioticFacet). One will be adopted in v1.1; until then, implementations MAY support either, both, or neither." ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:revokedBy a owl:ObjectProperty ;
    rdfs:label "revoked by (Proposal A)" ;
    rdfs:comment "Links a RevocationFacet to one or more RevocationConditions. Proposal A form." ;
    rdfs:domain iep:RevocationFacet ;
    rdfs:range iep:RevocationCondition ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Proposal B — predicate on SemioticFacet ──────────────────

iep:revokedIf a owl:ObjectProperty ;
    rdfs:label "revoked if (Proposal B)" ;
    rdfs:comment "DRAFT. Attaches one or more RevocationConditions to a SemioticFacet. When any linked condition's successorQuery returns a hit, the enclosing descriptor's effective groundTruth transitions per the RevocationAction. Proposal B of the revocation extension spec; preserves the exactly-core-facet invariant by nesting revocation inside the Semiotic facet's truth-state unit rather than adding a new facet type. Rival: Proposal A (iep:RevocationFacet)." ;
    rdfs:domain iep:SemioticFacet ;
    rdfs:range iep:RevocationCondition ;
    vs:term_status "testing" ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Hypermedia + SHACL discipline on kernel + shim responses ──
#
# Every kernel-verb / shim response carries a JSON-LD envelope that
# references one of the shapes below via iep:conformsToShape, so SHACL
# validators can verify the wire shape without out-of-band schema.
# These shapes describe the *response envelope* — the underlying
# domain types (ContextDescriptor, ContextFacet, ...) are shaped
# above.

iep:Holon a owl:Class ;
    rdfs:label "Holon" ;
    rdfs:comment "A dereferenceable IRI together with its level + kind in the substrate (atom / fragment / descriptor / manifest / opaque). The atomic unit kernel verbs operate on." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── Container + conformance gate vocabulary ────────────────────
#
# A iep:Container is a pod-side aggregate (LDP BasicContainer / Solid
# folder) that hosts iep:Holon resources. Containers MAY declare
# property/shape/capability metadata via iep:declares, and MAY constrain
# every Holon written under them to satisfy a sh:NodeShape via
# iep:conformsTo. The relay's publish gate enforces iep:conformsTo at
# write time (deploy/mcp-relay/server.ts) — non-conformant Holons are
# rejected before the CSS write so the container's invariants hold
# everywhere a federation reader sees the container.

iep:Container a owl:Class ;
    rdfs:label "Container"@en ;
    rdfs:comment "A pod-side aggregate (Solid / LDP BasicContainer or equivalent) that hosts iep:Holon resources. Containers MAY declare container-level metadata via iep:declares (properties, shapes, vocabulary terms, capabilities) and MAY constrain every Holon written under them to satisfy a sh:NodeShape via iep:conformsTo. Aligned with ldp:BasicContainer; treated as a kind of iep:Holon so the substrate can reason uniformly about the container and its contents."@en ;
    rdfs:subClassOf iep:Holon ;
    rdfs:seeAlso ldp:BasicContainer ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:conformsTo a owl:ObjectProperty ;
    rdfs:label "conforms to"@en ;
    rdfs:domain iep:Holon ;
    rdfs:range sh:NodeShape ;
    rdfs:comment "Asserts that the subject conforms to the indicated SHACL NodeShape. When attached to a container, every Holon written to that container MUST validate against the shape; the publish gate rejects non-conformant writes."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:declares a owl:ObjectProperty ;
    rdfs:label "declares"@en ;
    rdfs:domain iep:Container ;
    rdfs:range owl:Thing ;
    rdfs:comment "A container declares a property, shape, vocabulary term, or capability. Used to make container-level metadata discoverable (e.g. iep:declares iep:Conformant, iep:declares <shape IRI>)."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── PGSL lattice holon subtypes ───────────────────────────────
#
# The kernel emits these substrate types in dereference responses
# (packages/core/src/kernel/index.ts:364–367) — they reify the
# level-0 vs level-N distinction in the PGSL Grothendieck-fibration
# lattice as first-class typed subclasses of iep:Holon.

iep:Atom a owl:Class ;
    rdfs:subClassOf iep:Holon ;
    rdfs:label "Atom"@en ;
    rdfs:comment "PGSL level-0 holon — a content-addressed scalar value forming the base of the lattice. Has no internal composition; its iep:value produces its content-address URI."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:Fragment a owl:Class ;
    rdfs:subClassOf iep:Holon ;
    rdfs:label "Fragment"@en ;
    rdfs:comment "PGSL level-N (N>=1) holon — a typed-hyperedge composition over constituent iep:Atoms or lower-level iep:Fragments referenced through iep:items."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:level a owl:DatatypeProperty ;
    rdfs:domain iep:Holon ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:label "level"@en ;
    rdfs:comment "PGSL fibration level — 0 for iep:Atom, N>=1 for iep:Fragment composed over level-(N-1) constituents."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:value a owl:DatatypeProperty ;
    rdfs:domain iep:Holon ;
    rdfs:range xsd:string ;
    rdfs:label "value"@en ;
    rdfs:comment "Recursive string projection of a holon's content — for iep:Atom, the scalar value that produces the atom's content-address URI; for iep:Fragment, the concatenated projection of its items."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:items a owl:ObjectProperty ;
    rdfs:domain iep:Fragment ;
    rdfs:range iep:Holon ;
    rdfs:label "items"@en ;
    rdfs:comment "Ordered references to the constituents of a iep:Fragment — lower-level iep:Atoms or iep:Fragments composed at this level."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ─── PGSL projection vocabulary ────────────────────────────────
#
# The foundation-first projection engine (packages/pgsl/src/projection.ts +
# packages/solid/src/client.ts) projects a PGSL lattice node into a
# iep:ContextDescriptor / manifest entry that carries a stable pointer back
# to the lattice node it was projected from, plus an optional link to the
# node's encrypted on-pod payload. These terms make that projection
# self-describing so a reader can recover the lattice coordinate of any
# projected descriptor.

iep:EncryptedHolon a owl:Class ;
    rdfs:subClassOf iep:Holon ;
    rdfs:label "Encrypted Holon"@en ;
    rdfs:comment "A holon whose payload is stored as an encrypted (JOSE) envelope on a pod. The clear lattice identity (iep:pgslUri) and its owning descriptor (iep:ofDescriptor) remain visible for discovery, while the value bytes are recoverable only by an envelope recipient. Projected by the foundation-first projection engine alongside the descriptor that describes it."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:XFacet a owl:Class ;
    rdfs:subClassOf iep:ContextFacet ;
    rdfs:label "Projection Cross-Cut Facet"@en ;
    rdfs:comment "A deterministic, clock-free facet attached to a projected descriptor (emitted as iep:hasFacet [ a iep:XFacet … ]) that records the PGSL lattice coordinate (iep:pgslUri / iep:pgslLevel) of the node the descriptor was projected from. Pure projection metadata — its presence lets the same lattice node project to byte-identical descriptors across pods."@en ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:pgslUri a owl:ObjectProperty ;
    rdfs:label "PGSL URI"@en ;
    rdfs:comment "Content-addressed IRI of the PGSL lattice node (pgsl:Node) that a descriptor, manifest entry, or iep:EncryptedHolon was projected from. The stable lattice coordinate: equal content projects to the same pgslUri across pods."@en ;
    rdfs:range pgsl:Node ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:pgslLevel a owl:DatatypeProperty ;
    rdfs:label "PGSL level"@en ;
    rdfs:comment "The PGSL fibration level of the projected lattice node — 0 for an atom, N>=1 for a fragment composed over level-(N-1) constituents. Carried on projected descriptors / manifest entries so a reader knows the granularity of the projection without dereferencing the lattice."@en ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:encryptedHolon a owl:ObjectProperty ;
    rdfs:label "encrypted holon"@en ;
    rdfs:comment "Links a projected iep:ContextDescriptor to the iep:EncryptedHolon resource holding its encrypted payload on the pod. Present only when the projection produced an encrypted on-pod artifact."@en ;
    rdfs:domain iep:ContextDescriptor ;
    rdfs:range iep:EncryptedHolon ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ofDescriptor a owl:ObjectProperty ;
    rdfs:label "of descriptor"@en ;
    rdfs:comment "Inverse-direction link from an iep:EncryptedHolon back to the iep:ContextDescriptor it is the encrypted payload of. Lets a reader who dereferenced the holon recover its describing descriptor."@en ;
    rdfs:domain iep:EncryptedHolon ;
    rdfs:range iep:ContextDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:contentCid a owl:DatatypeProperty ;
    rdfs:label "content CID"@en ;
    rdfs:comment "Content identifier (CID) of a descriptor's canonical bytes, carried on projected descriptors and manifest entries so content-addressed supersession gates can compare versions without re-fetching the full payload."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:HolonShape a sh:NodeShape ;
    rdfs:label "Holon SHACL shape" ;
    sh:targetClass iep:Holon ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:KernelResultShape a sh:NodeShape ;
    rdfs:label "Kernel result envelope SHACL shape" ;
    sh:targetClass iep:KernelResult ;
    rdfs:comment "Base shape every kernel-verb / shim response satisfies — requires JSON-LD typing + at least one iep:Affordance hint for next-step navigation." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:MintResultShape a sh:NodeShape ;
    rdfs:label "Mint result SHACL shape" ;
    sh:targetClass iep:MintResult ;
    rdfs:comment "Result envelope of kernel.mint — wraps a freshly minted iep:Holon." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:RestrictResultShape a sh:NodeShape ;
    rdfs:label "Restrict result SHACL shape" ;
    sh:targetClass iep:RestrictResult ;
    rdfs:comment "Result envelope of kernel.restrict — narrowed iep:ContextDescriptor." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ExtendResultShape a sh:NodeShape ;
    rdfs:label "Extend result SHACL shape" ;
    sh:targetClass iep:ExtendResult ;
    rdfs:comment "Result envelope of kernel.extend — widened iep:ContextDescriptor." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ToolResult a owl:Class ;
    rdfs:label "Tool result envelope" ;
    rdfs:comment "Compatibility-shim response envelope — the @type every named-tool (non-kernel-verb) MCP shim emits, shaped by iep:ToolResultShape." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ToolResultShape a sh:NodeShape ;
    rdfs:label "Tool result envelope SHACL shape" ;
    sh:targetClass iep:ToolResult ;
    rdfs:comment "Base shape every named-tool shim response satisfies — same envelope discipline as kernel verbs." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:RelayEntryPoint a owl:Class ;
    rdfs:label "Relay entry point" ;
    rdfs:comment "Top-level Hydra entry-point envelope a hosted MCP relay advertises — co-typed with hydra:EntryPoint and shaped by iep:RelayEntryPointShape; its affordances list the relay's surface operations." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:RelayEntryPointShape a sh:NodeShape ;
    rdfs:label "Relay entry point SHACL shape" ;
    sh:targetClass iep:RelayEntryPoint ;
    rdfs:comment "Hypermedia entry point document for an HTTP relay's surface — every operation listed MUST be a hydra:Operation." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:AffordanceShape a sh:NodeShape ;
    rdfs:label "Affordance SHACL shape" ;
    sh:targetClass iep:Affordance ;
    rdfs:comment "A iep:Affordance MUST also be a hydra:Operation with iep:action + hydra:target + hydra:method." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:DereferenceResultShape a sh:NodeShape ;
    rdfs:label "Dereference result SHACL shape" ;
    rdfs:comment "Result envelope of kernel.dereference — carries the fetched representation + extracted affordances." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ComposeResultShape a sh:NodeShape ;
    rdfs:label "Compose result SHACL shape" ;
    rdfs:comment "Result envelope of kernel.compose — emits a ComposedDescriptor witness." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ActResultShape a sh:NodeShape ;
    rdfs:label "Act result SHACL shape" ;
    rdfs:comment "Result envelope of kernel.act — wraps an HTTP response and echoes the followed affordance." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:PromoteResultShape a sh:NodeShape ;
    rdfs:label "Promote result SHACL shape" ;
    rdfs:comment "Result envelope of kernel.promote — apex IRI + lattice level + optional pullback square." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:DecomposeResultShape a sh:NodeShape ;
    rdfs:label "Decompose result SHACL shape" ;
    rdfs:comment "Result envelope of kernel.decompose — pullback square (apex + left + right + overlap)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:ManifestShape a sh:NodeShape ;
    rdfs:label "Manifest SHACL shape" ;
    rdfs:comment "A pod's .well-known/context-graphs manifest is a hydra:Collection of iep:ContextDescriptor entries." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:conformsToShape a owl:ObjectProperty ;
    rdfs:label "conforms to shape" ;
    rdfs:comment "Links a response envelope to the SHACL node shape it satisfies. Spiritual sibling of dct:conformsTo, specialised for sh:NodeShape targets." ;
    rdfs:range sh:NodeShape ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:iri a owl:DatatypeProperty ;
    rdfs:label "iri" ;
    rdfs:comment "The dereferenceable IRI of a holon or response envelope. Wire-level shortcut used in kernel result documents." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "Substrate-level status code on a kernel-verb response (ok / encrypted-no-key / not-found / error)." ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:httpStatus a owl:DatatypeProperty ;
    rdfs:label "http status" ;
    rdfs:comment "Numeric HTTP status code echoed by kernel.act and dereference result envelopes when the underlying transport is HTTP." ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:apex a owl:ObjectProperty ;
    rdfs:label "apex" ;
    rdfs:comment "The apex fragment IRI of a PGSL pullback square. Used by promote and decompose result envelopes." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:kind a owl:DatatypeProperty ;
    rdfs:label "kind" ;
    rdfs:comment "Holon role within the substrate — one of 'atom' (PGSL level-0 scalar), 'fragment' (PGSL level-N composition), 'descriptor' (iep:ContextDescriptor envelope), 'manifest' (hydra:Collection manifest), or 'opaque' (dereferenceable but uninterpreted)." ;
    rdfs:domain iep:Holon ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:left a owl:ObjectProperty ;
    rdfs:label "left" ;
    rdfs:comment "Left leg of a PGSL pullback square emitted by kernel.decompose — the first sub-fragment whose intersection with iep:right is iep:overlap and whose join is iep:apex." ;
    rdfs:domain iep:ComposedDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:right a owl:ObjectProperty ;
    rdfs:label "right" ;
    rdfs:comment "Right leg of a PGSL pullback square emitted by kernel.decompose — the second sub-fragment whose intersection with iep:left is iep:overlap and whose join is iep:apex." ;
    rdfs:domain iep:ComposedDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:overlap a owl:ObjectProperty ;
    rdfs:label "overlap" ;
    rdfs:comment "Shared sub-fragment at the meet of iep:left and iep:right in a PGSL pullback square emitted by kernel.decompose." ;
    rdfs:domain iep:ComposedDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

# ══════════════════════════════════════════════════════════════
#  SolidNotifications — descriptor-lifecycle event format
# ══════════════════════════════════════════════════════════════

iep:Notification a owl:Class ;
    rdfs:label "Notification" ;
    rdfs:comment "A descriptor-lifecycle event emitted by a relay or pod implementing the iep:FederationFacet syncProtocol 'SolidNotifications' contract. Carries the IRI of the descriptor that changed, the kind of change (created / updated / superseded), the producing pod, the timestamp, and optionally the authoring agent. Delivered over Server-Sent Events (text/event-stream) at GET /notifications/:podSlug and/or POSTed to registered webhook URLs as application/ld+json." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:NotificationChannelOpen a owl:Class ;
    rdfs:subClassOf iep:Notification ;
    rdfs:label "Notification Channel Open" ;
    rdfs:comment "A control event sent by a SolidNotifications SSE endpoint as the first data frame after the HTTP headers flush. Confirms the channel is alive and carries the resolved pod URL + slug so the client can sanity-check the routing before processing subsequent iep:Notification events." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:eventType a owl:DatatypeProperty ;
    rdfs:label "event type" ;
    rdfs:comment "Kind of descriptor lifecycle event — one of 'created' (new descriptor minted), 'updated' (existing descriptor's payload or facets changed in place), or 'superseded' (a successor descriptor was published via iep:supersedes and the prior head is no longer the canonical view)." ;
    rdfs:domain iep:Notification ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:podUrl a owl:DatatypeProperty ;
    rdfs:label "pod URL" ;
    rdfs:comment "The Solid pod URL the notification originated from. Combined with iep:descriptorUrl it locates the changed resource without requiring the consumer to maintain a separate pod-to-descriptor index." ;
    rdfs:domain iep:Notification ;
    rdfs:range xsd:anyURI ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:descriptorUrl a owl:DatatypeProperty ;
    rdfs:label "descriptor URL" ;
    rdfs:comment "Dereferenceable IRI of the iep:ContextDescriptor a notification refers to. Used in iep:Notification events to identify the changed descriptor without forcing the consumer to parse the event payload's structure." ;
    rdfs:range xsd:anyURI ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:graphUrl a owl:DatatypeProperty ;
    rdfs:label "graph URL" ;
    rdfs:comment "Dereferenceable IRI of the iep:ContextDescriptor's payload graph (the .nq / .envelope.jose.json artifact). Carried alongside iep:descriptorUrl in iep:Notification events so a consumer can fetch the payload without first re-fetching the descriptor index." ;
    rdfs:range xsd:anyURI ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> .

iep:NotificationShape a sh:NodeShape ;
    rdfs:label "Notification SHACL shape" ;
    rdfs:comment "Validation shape for iep:Notification events delivered over Server-Sent Events or as JSON-LD webhook payloads. Every event MUST carry a podUrl, descriptorUrl, eventType (one of created / updated / superseded), and a timestamp. graphUrl and author are optional but RECOMMENDED. Implementations honoring the FederationFacet syncProtocol 'SolidNotifications' contract conform to this shape." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#> ;
    sh:targetClass iep:Notification ;
    sh:property [
        sh:path iep:podUrl ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:Notification MUST carry exactly one iep:podUrl identifying the source pod."
    ] ;
    sh:property [
        sh:path dct:source ;
        sh:minCount 0
    ] ;
    sh:property [
        sh:path iep:descriptorUrl ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:Notification MUST carry exactly one iep:descriptorUrl identifying the changed descriptor."
    ] ;
    sh:property [
        sh:path iep:eventType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( "created" "updated" "superseded" ) ;
        sh:message "iep:eventType MUST be one of 'created', 'updated', or 'superseded'."
    ] ;
    sh:property [
        sh:path dct:created ;
        sh:datatype xsd:dateTime ;
        sh:minCount 0 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path prov:wasAttributedTo ;
        sh:minCount 0 ;
        sh:maxCount 1
    ] .
