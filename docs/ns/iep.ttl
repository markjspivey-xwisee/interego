iep:consentBasis a owl:ObjectProperty ; rdfs:label "consent basis" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:hasDistribution a owl:ObjectProperty ; rdfs:label "has distribution" ; rdfs:comment "Legacy shim for descriptors written before canonical iep:affordance form. Prefer iep:affordance [ a dcat:Distribution ... ]." ; rdfs:range dcat:Distribution ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:algorithm a owl:DatatypeProperty ; rdfs:label "algorithm" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:cid a owl:DatatypeProperty ; rdfs:label "CID" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:contentHash a owl:DatatypeProperty ; rdfs:label "content hash" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:gatewayUrl a owl:DatatypeProperty ; rdfs:label "gateway URL" ; rdfs:range xsd:anyURI ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:pinnedAt a owl:DatatypeProperty ; rdfs:label "pinned at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:pinnedBy a owl:ObjectProperty ; rdfs:label "pinned by" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:provider a owl:DatatypeProperty ; rdfs:label "provider" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:signature a owl:DatatypeProperty ; rdfs:label "signature" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:signedAt a owl:DatatypeProperty ; rdfs:label "signed at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:signerAddress a owl:DatatypeProperty ; rdfs:label "signer address" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:encryptedAt a owl:DatatypeProperty ; rdfs:label "encrypted at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:recipientFingerprint a owl:DatatypeProperty ; rdfs:label "recipient fingerprint" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:owner a owl:ObjectProperty ; rdfs:label "owner" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:ingestedAt a owl:DatatypeProperty ; rdfs:label "ingested at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:promotedAt a owl:DatatypeProperty ; rdfs:label "promoted at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:registeredAt a owl:DatatypeProperty ; rdfs:label "registered at" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:lastSeen a owl:DatatypeProperty ; rdfs:label "last seen" ; rdfs:range xsd:dateTime ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:wasAttributedTo a owl:ObjectProperty ; rdfs:label "was attributed to" ; rdfs:comment "Legacy shim for prov:wasAttributedTo usage inside iep: emissions. Prefer prov:wasAttributedTo directly." ; rdfs:seeAlso prov:wasAttributedTo ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:causes a owl:ObjectProperty ; rdfs:label "causes" ; rdfs:domain iep:CausalEdge ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:effectOf a owl:ObjectProperty ; rdfs:label "effect of" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:effectSize a owl:DatatypeProperty ; rdfs:label "effect size" ; rdfs:range xsd:double ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:mechanism a owl:DatatypeProperty ; rdfs:label "mechanism" ; rdfs:range xsd:string ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:intervenes a owl:ObjectProperty ; rdfs:label "intervenes" ; rdfs:domain iep:Intervention ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
iep:interventionValue a owl:DatatypeProperty ; rdfs:label "intervention value" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
