@prefix cts:  <https://markjspivey-xwisee.github.io/interego/ns/cts#> .
@prefix cg:   <https://markjspivey-xwisee.github.io/interego/ns/cg#> .
@prefix pgsl: <https://markjspivey-xwisee.github.io/interego/ns/pgsl#> .
@prefix cgh:  <https://markjspivey-xwisee.github.io/interego/ns/harness#> .
@prefix ie:   <https://markjspivey-xwisee.github.io/interego/ns/interego#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

# ══════════════════════════════════════════════════════════════
#  CTS — Compositional Tuple Store
# ══════════════════════════════════════════════════════════════
#
#  CTS grounds Interego's semantic machinery in usage-based
#  linguistics: meaning is usage, structure emerges from usage
#  rather than being imposed a-priori. The tuple store records
#  actual usage events; structure (paradigms, constraints,
#  syntagmatic patterns) emerges as statistical regularity
#  over those events.
#
#  Core principle (Langacker, Tomasello, Bybee): no word has
#  meaning in isolation; meaning is the distribution of contexts
#  in which the word has been used. CTS makes this concrete:
#
#    - Every utterance is a Tuple (positions × fillers × context)
#    - Regularities across tuples are Patterns
#    - Patterns constrain future tuple assembly
#    - Interoperability between agents is Emergent rather than
#      engineered — two agents using the same tuples converge on
#      compatible patterns without a shared pre-specified schema
#
#  CTS underlies PGSL's atom/fragment lattice: every PGSL atom is
#  a tuple filler; every PGSL fragment is a position × filler
#  binding; the overlapping-pair construction at each level is a
#  CTS pattern-inference step.

<https://markjspivey-xwisee.github.io/interego/ns/cts>
    a owl:Ontology ;
    dct:title "CTS — Compositional Tuple Store" ;
    dct:description "Usage-based linguistic substrate. Records utterances as tuples (positions × fillers × context); infers patterns as statistical regularities; lets interoperability emerge without a pre-specified schema. Underlies PGSL at the substrate layer and cg:ParadigmSet / cg:SyntagmaticPattern at the grammar layer." ;
    vann:preferredNamespacePrefix "cts" ;
    vann:preferredNamespaceUri "https://markjspivey-xwisee.github.io/interego/ns/cts#" ;
    owl:imports <https://markjspivey-xwisee.github.io/interego/ns/pgsl> ,
                <https://markjspivey-xwisee.github.io/interego/ns/cg> .

cts:Tuple a owl:Class ;
    rdfs:label "Tuple" ;
    rdfs:comment "A single usage record: a sequence of positions, each filled by a specific filler, observed in a specific context. Realized as a pgsl:Fragment — the atomic unit of the CTS." ;
    rdfs:subClassOf pgsl:Fragment .

cts:Position a owl:Class ;
    rdfs:label "Position" ;
    rdfs:comment "A slot in a tuple where a filler may appear. Positions are ordered and typed by the paradigm set of fillers admissible there. A structural coordinate in a pgsl:Fragment." ;
    rdfs:subClassOf pgsl:Atom .

cts:Filler a owl:Class ;
    rdfs:label "Filler" ;
    rdfs:comment "A value occupying a position in a tuple. Can be a pgsl:Atom, a cg:ContextDescriptor, a WebID, or any IRI-addressable entity." ;
    rdfs:subClassOf pgsl:Atom .

cts:Context a owl:Class ;
    rdfs:label "Usage Context" ;
    rdfs:comment "The surrounding environment of a tuple — time, place, agents present, prior tuples, task being performed. Realized as a cg:ContextDescriptor that accompanies the tuple." ;
    rdfs:subClassOf cg:ContextDescriptor .

cts:Pattern a owl:Class ;
    rdfs:label "Usage Pattern" ;
    rdfs:comment "A statistical regularity across tuples — e.g. 'position 1 is almost always filled by a hela:Actor' or 'position 3 and position 5 correlate'. Learned from observed tuples, not declared." ;
    owl:equivalentClass cg:SyntagmaticPattern .

cts:ParadigmSet a owl:Class ;
    rdfs:subClassOf cg:ParadigmSet ;
    rdfs:label "CTS Paradigm Set" ;
    rdfs:comment "The distribution of fillers observed at a given position across all tuples. Used to infer the class of fillers valid at that position (i.e. the paradigm) — cf. Saussure's paradigmatic axis." .

cts:Emergence a owl:Class ;
    rdfs:label "Emergence" ;
    rdfs:comment "The phenomenon by which interoperability between agents arises without explicit schema agreement. Two agents using the same tuples converge on compatible patterns; the emergence is the quantitative observation that their patterns align over time. Constructed from sets of cts:Pattern via cross-agent comparison." ;
    cg:constructedFrom ( cts:Pattern cts:Pattern ) .

# ── Properties ────────────────────────────────────────────────

cts:hasPosition a owl:ObjectProperty ;
    rdfs:label "has position" ;
    rdfs:domain cts:Tuple ;
    rdfs:range cts:Position .

cts:hasFiller a owl:ObjectProperty ;
    rdfs:label "has filler" ;
    rdfs:domain cts:Position ;
    rdfs:range cts:Filler .

cts:usedIn a owl:ObjectProperty ;
    rdfs:label "used in" ;
    rdfs:domain cts:Filler ;
    rdfs:range cts:Context .

cts:inducesPattern a owl:ObjectProperty ;
    rdfs:label "induces pattern" ;
    rdfs:comment "Relates a set of tuples to the pattern they collectively evidence. Inverse of pattern membership." ;
    rdfs:range cts:Pattern .

# ── Alignments ────────────────────────────────────────────────

cts:Tuple rdfs:seeAlso pgsl:Fragment ;
    rdfs:comment "A pgsl:Fragment at level N is a tuple whose fillers are themselves fragments at level N-1 — the overlapping-pair construction is tuple composition. CTS and PGSL are two views of the same structure: CTS emphasises usage + emergence, PGSL emphasises content-addressed lattice algebra." .

cts:Pattern owl:equivalentClass cg:SyntagmaticPattern ;
    rdfs:comment "CTS patterns and cg:SyntagmaticPattern are the same concept at two different abstraction layers — CTS at the raw usage layer, cg: at the typed-context layer. Explicit equivalence lets tooling navigate freely between them." .

# ══════════════════════════════════════════════════════════════
#  Sub-token compositional reuse (n-gram canonicalization)
# ══════════════════════════════════════════════════════════════
#
#  Make substructure sharing explicit at the character / n-gram
#  layer: a single n-gram type is canonical (one IRI); occurrences
#  in containing tuples are typed morphisms with offset and length.
#  This realizes the BPE-as-colimit pattern — the n-gram vocabulary
#  is a generating set of typed holons; tokens compose them via
#  inclusion morphisms; substructure sharing falls out of IRI
#  equality at the n-gram layer with no canonicalization step.
#
#  Companion to docs/ARCHITECTURAL-FOUNDATIONS.md §5 invariant 4
#  (hyperedge composition as colimit) and §7 (CTS as the tuple-store
#  realization).

cts:CharacterAtom a owl:Class ;
    rdfs:label "Character Atom" ;
    rdfs:comment "An atomic glyph holon — a single character at the smallest granularity. Identity is content-addressed (urn:pgsl:atom:<sha256-of-character>). Two distinct occurrences of 'm' across all tuples share one CharacterAtom IRI." ;
    rdfs:subClassOf pgsl:Atom .

cts:NGram a owl:Class ;
    rdfs:label "N-gram" ;
    rdfs:comment "A canonical, deduplicated sequence of CharacterAtoms (or higher-level fillers). Identity is content-addressed: two tuples containing the same bigram literally share the NGram IRI. The vocabulary of NGrams is the generating set of the BPE-as-colimit construction." ;
    rdfs:subClassOf cts:Tuple .

cts:Occurrence a owl:Class ;
    rdfs:label "N-gram Occurrence" ;
    rdfs:comment "A typed morphism recording that a specific NGram appears in a specific containing tuple at a specific offset. Conceptually a hyperedge (NGram, ContainingTuple, offset, length). Querying 'what tokens share substructure with X' is a SPARQL join through this class — substructure sharing is graph topology, not algorithm." .

cts:ngram a owl:ObjectProperty ;
    rdfs:label "ngram" ;
    rdfs:domain cts:Occurrence ;
    rdfs:range cts:NGram ;
    rdfs:comment "The canonical n-gram resource being instantiated by this occurrence. Multiple Occurrences across different containing tuples may share the same cts:ngram value — that is the substructure-sharing relation made explicit." .

cts:within a owl:ObjectProperty ;
    rdfs:label "within" ;
    rdfs:domain cts:Occurrence ;
    rdfs:range cts:Tuple ;
    rdfs:comment "The tuple this occurrence lives inside. Structurally: a parent in the holon hierarchy. The Janus-flip is observable here — the NGram is a whole over its CharacterAtoms AND a part within this containing tuple via the Occurrence." .

cts:offset a owl:DatatypeProperty ;
    rdfs:label "offset" ;
    rdfs:domain cts:Occurrence ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Zero-based starting position of the n-gram within the containing tuple." .

cts:length a owl:DatatypeProperty ;
    rdfs:label "length" ;
    rdfs:domain cts:Occurrence ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Number of constituent atoms / characters in the occurrence. Together with cts:offset uniquely locates the inclusion morphism within the containing tuple." .

# ══════════════════════════════════════════════════════════════
#  Position-as-resource (Hydra controls)
# ══════════════════════════════════════════════════════════════
#
#  Promote cts:Position from an implicit ordering coordinate to a
#  first-class typed resource with hypermedia link relations. Lets
#  agents do typed link-walks at character / token / fragment
#  granularity without parsing content — what you walk are positions
#  with cts:next links, not strings with index arithmetic.
#
#  The pattern: each cts:Tuple has cts:Position resources for each
#  of its slots; positions carry cts:next / cts:previous so a generic
#  affordance-walking agent (Path A in the demos) can traverse them
#  via Hydra controls, just as it would walk any other typed graph.

cts:next a owl:ObjectProperty ;
    rdfs:label "next" ;
    rdfs:domain cts:Position ;
    rdfs:range cts:Position ;
    rdfs:comment "Hydra-style link relation pointing to the immediately-following position in the same tuple. Absent on the last position. Lets an agent walk a tuple's positions without numerical indexing — the same pattern as following a paginated collection." .

cts:previous a owl:ObjectProperty ;
    owl:inverseOf cts:next ;
    rdfs:label "previous" ;
    rdfs:domain cts:Position ;
    rdfs:range cts:Position ;
    rdfs:comment "Inverse of cts:next; absent on the first position." .

cts:withinTuple a owl:ObjectProperty ;
    rdfs:label "within tuple" ;
    rdfs:domain cts:Position ;
    rdfs:range cts:Tuple ;
    rdfs:comment "The tuple this position belongs to. Structurally: the parent in the holon hierarchy. Inverse of cts:hasPosition." .

# ══════════════════════════════════════════════════════════════
#  Worked example (informative)
# ══════════════════════════════════════════════════════════════
#
#  The token 'mark' decomposes into four CharacterAtoms via four
#  cts:Position resources, with two NGram inclusions (the bigram
#  'ma' shared with 'human', and the 4-gram 'mark' itself):
#
#    <urn:cts:token:mark> a cts:Tuple ;
#      cts:hasPosition <urn:cts:pos:mark:0>, <urn:cts:pos:mark:1>,
#                      <urn:cts:pos:mark:2>, <urn:cts:pos:mark:3> .
#
#    <urn:cts:pos:mark:0> a cts:Position ;
#      cts:hasFiller <urn:char:m> ;
#      cts:withinTuple <urn:cts:token:mark> ;
#      cts:next <urn:cts:pos:mark:1> .
#    # ... positions 1, 2, 3 similarly ...
#
#    <urn:cts:occurrence:ma-in-mark-at-0> a cts:Occurrence ;
#      cts:ngram <urn:cts:ngram:ma> ;
#      cts:within <urn:cts:token:mark> ;
#      cts:offset 0 ;
#      cts:length 2 .
#
#    <urn:cts:occurrence:ma-in-human-at-2> a cts:Occurrence ;
#      cts:ngram <urn:cts:ngram:ma> ;       # <-- same IRI!
#      cts:within <urn:cts:token:human> ;
#      cts:offset 2 ;
#      cts:length 2 .
#
#  The n-gram 'ma' is one resource. Both occurrences point at it.
#  Querying "what tokens share substructure with 'mark'?" via SPARQL:
#
#    SELECT DISTINCT ?other WHERE {
#      ?occ_a cts:within <urn:cts:token:mark> ; cts:ngram ?ng .
#      ?occ_b cts:within ?other ; cts:ngram ?ng .
#      FILTER(?other != <urn:cts:token:mark>)
#    }
#
#  Returns 'human' for free, with no canonicalization or detection
#  step — the sharing relation is graph topology. This is the
#  practical realization of foundations §5 invariant 4 (hyperedge
#  composition as colimit).
