@prefix ieh:  <https://markjspivey-xwisee.github.io/interego/ns/harness#> .
@prefix pgsl: <https://markjspivey-xwisee.github.io/interego/ns/pgsl#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# ══════════════════════════════════════════════════════════════
#  Interego Harness 1.0 SHACL Shapes
# ══════════════════════════════════════════════════════════════
#
#  Validates harness ontology instances:
#    - AATs have at least one canPerceive AND one canAct
#    - Policy rules have a mode + subject + action
#    - Policy decisions reference at least one matched rule
#    - PROV traces extend prov:Activity correctly
#    - Runtime evals have confidence in [0,1] and a recommended action
#    - Decorated affordances carry decorator id, trust level, confidence
#    - Personal brokers reference an AAT
# ══════════════════════════════════════════════════════════════

<https://markjspivey-xwisee.github.io/interego/ns/harness-shapes#>
    a owl:Ontology ;
    owl:versionInfo "1.0" ;
    dct:title "Interego Harness 1.0 SHACL Shapes" ;
    dct:description "SHACL validation shapes for the harness ontology." ;
    dct:license <https://opensource.org/licenses/MIT> ;
    dct:created "2026-04-13"^^xsd:date ;
    rdfs:seeAlso <https://markjspivey-xwisee.github.io/interego/ns/harness#> .

# ══════════════════════════════════════════════════════════════
#  AAT Shape
# ══════════════════════════════════════════════════════════════

ieh:AbstractAgentTypeShape a sh:NodeShape ;
    sh:targetClass ieh:AbstractAgentType ;
    rdfs:comment "An AAT must declare at least one capability and one action it can perform. mustPreserve is optional but recommended." ;

    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "label" ;
        sh:message "Every AAT must have an rdfs:label."
    ] ;

    sh:property [
        sh:path ieh:canPerceive ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "canPerceive" ;
        sh:message "An AAT must declare at least one canPerceive capability."
    ] ;

    sh:property [
        sh:path ieh:canAct ;
        sh:minCount 0 ;
        sh:datatype xsd:string ;
        sh:name "canAct" ;
        sh:description "May be empty for read-only AATs like Observer."
    ] ;

    sh:property [
        sh:path ieh:maxConcurrent ;
        sh:datatype xsd:positiveInteger ;
        sh:maxCount 1 ;
        sh:name "maxConcurrent"
    ] .

# ══════════════════════════════════════════════════════════════
#  Policy Rule Shape
# ══════════════════════════════════════════════════════════════

ieh:PolicyRuleShape a sh:NodeShape ;
    sh:targetClass ieh:PolicyRule ;
    rdfs:comment "A policy rule must have a deontic mode, a subject, an action, and a human-readable reason. The target is optional (defaults to '*')." ;

    sh:property [
        sh:path ieh:mode ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ieh:DeonticMode ;
        sh:name "mode" ;
        sh:message "A PolicyRule must have exactly one ieh:mode."
    ] ;

    sh:property [
        sh:path ieh:subject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "subject" ;
        sh:message "A PolicyRule must have exactly one ieh:subject."
    ] ;

    sh:property [
        sh:path ieh:action ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "action" ;
        sh:message "A PolicyRule must have exactly one ieh:action."
    ] ;

    sh:property [
        sh:path ieh:ruleTarget ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name "ruleTarget"
    ] ;

    sh:property [
        sh:path ieh:reason ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name "reason"
    ] .

# ══════════════════════════════════════════════════════════════
#  Policy Decision Shape
# ══════════════════════════════════════════════════════════════

ieh:PolicyDecisionShape a sh:NodeShape ;
    sh:targetClass ieh:PolicyDecision ;
    rdfs:comment "A policy decision must have allowed (boolean), reason (string), and at least one matched rule (unless allowed=true with no rules). Modeled as a prov:Activity so PROV invariants apply." ;

    sh:property [
        sh:path ieh:allowed ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "allowed" ;
        sh:message "A PolicyDecision must have exactly one ieh:allowed."
    ] ;

    sh:property [
        sh:path ieh:reason ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "reason" ;
        sh:message "A PolicyDecision must have exactly one ieh:reason."
    ] ;

    sh:property [
        sh:path ieh:matchedRule ;
        sh:class ieh:PolicyRule ;
        sh:name "matchedRule"
    ] ;

    sh:property [
        sh:path prov:startedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:name "startedAtTime"
    ] ;

    sh:property [
        sh:path prov:endedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:name "endedAtTime"
    ] .

# ══════════════════════════════════════════════════════════════
#  PROV Trace Shape
# ══════════════════════════════════════════════════════════════

ieh:ProvTraceShape a sh:NodeShape ;
    sh:targetClass ieh:ProvTrace ;
    rdfs:comment "A PROV trace must reference an agent, an AAT, an activity start time, a success flag, and either a generated entity or a used entity." ;

    sh:property [
        sh:path prov:wasAssociatedWith ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "wasAssociatedWith" ;
        sh:message "Every ProvTrace must reference at least one prov:Agent via prov:wasAssociatedWith."
    ] ;

    sh:property [
        sh:path ieh:agentAAT ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ieh:AbstractAgentType ;
        sh:name "agentAAT" ;
        sh:message "Every ProvTrace must specify the AAT the agent was acting under."
    ] ;

    sh:property [
        sh:path prov:startedAtTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:name "startedAtTime" ;
        sh:message "Every ProvTrace must have prov:startedAtTime."
    ] ;

    sh:property [
        sh:path prov:endedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:name "endedAtTime"
    ] ;

    sh:property [
        sh:path ieh:success ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "success" ;
        sh:message "Every ProvTrace must have a ieh:success flag."
    ] ;

    sh:property [
        sh:path ieh:errorMessage ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name "errorMessage"
    ] ;

    sh:property [
        sh:path ieh:policyDecision ;
        sh:class ieh:PolicyDecision ;
        sh:maxCount 1 ;
        sh:name "policyDecision"
    ] .

# ══════════════════════════════════════════════════════════════
#  Runtime Eval Shape
# ══════════════════════════════════════════════════════════════

ieh:RuntimeEvalShape a sh:NodeShape ;
    sh:targetClass ieh:RuntimeEval ;
    rdfs:comment "A runtime evaluation must have a confidence in [0,1], a confidence level, structural signals, a recommended action, and an explanation." ;

    sh:property [
        sh:path ieh:confidence ;
        sh:datatype xsd:double ;
        sh:minInclusive "0.0"^^xsd:double ;
        sh:maxInclusive "1.0"^^xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "confidence" ;
        sh:message "Confidence must be a single double in [0.0, 1.0]."
    ] ;

    sh:property [
        sh:path ieh:level ;
        sh:class ieh:ConfidenceLevel ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "level"
    ] ;

    sh:property [
        sh:path ieh:signals ;
        sh:class ieh:StructuralSignals ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "signals"
    ] ;

    sh:property [
        sh:path ieh:recommendedAction ;
        sh:class ieh:EvalAction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "recommendedAction"
    ] ;

    sh:property [
        sh:path ieh:retryStrategy ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name "retryStrategy"
    ] ;

    sh:property [
        sh:path ieh:explanation ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "explanation"
    ] .

# ══════════════════════════════════════════════════════════════
#  Structural Signals Shape
# ══════════════════════════════════════════════════════════════

ieh:StructuralSignalsShape a sh:NodeShape ;
    sh:targetClass ieh:StructuralSignals ;
    rdfs:comment "Structural signals must include the four required numeric inputs and the question type / strategy / abstention flag." ;

    sh:property [
        sh:path ieh:sessionsMatched ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:sessionsTotal ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:topRetrievalScore ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:sharedAtoms ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:questionType ;
        sh:class ieh:QuestionType ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:strategyUsed ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:isAbstention ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Decorated Affordance Shape
# ══════════════════════════════════════════════════════════════

ieh:DecoratedAffordanceShape a sh:NodeShape ;
    sh:targetClass ieh:DecoratedAffordance ;
    rdfs:comment "A decorated affordance must reference its producing decorator and carry trust level + confidence." ;

    sh:property [
        sh:path ieh:decoratorId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "decoratorId"
    ] ;

    sh:property [
        sh:path ieh:decoratorName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "decoratorName"
    ] ;

    sh:property [
        sh:path ieh:trustLevel ;
        sh:class ieh:TrustLevel ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "trustLevel"
    ] ;

    sh:property [
        sh:path ieh:confidence ;
        sh:datatype xsd:double ;
        sh:minInclusive "0.0"^^xsd:double ;
        sh:maxInclusive "1.0"^^xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "confidence"
    ] ;

    sh:property [
        sh:path ieh:rationale ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name "rationale"
    ] .

# ══════════════════════════════════════════════════════════════
#  Affordance Decorator Shape
# ══════════════════════════════════════════════════════════════

ieh:AffordanceDecoratorShape a sh:NodeShape ;
    sh:targetClass ieh:AffordanceDecorator ;

    sh:property [
        sh:path ieh:decoratorId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:domain ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:trustLevel ;
        sh:class ieh:TrustLevel ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:priority ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Decision Shape
# ══════════════════════════════════════════════════════════════

ieh:DecisionShape a sh:NodeShape ;
    sh:targetClass ieh:Decision ;
    rdfs:comment "A decision must reference an affordance, have a confidence in [0,1], and provide a justification." ;

    sh:property [
        sh:path ieh:hasAffordance ;
        sh:class ieh:Affordance ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:confidence ;
        sh:datatype xsd:double ;
        sh:minInclusive "0.0"^^xsd:double ;
        sh:maxInclusive "1.0"^^xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:justification ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Decision Result Shape
# ══════════════════════════════════════════════════════════════

ieh:DecisionResultShape a sh:NodeShape ;
    sh:targetClass ieh:DecisionResult ;

    sh:property [
        sh:path ieh:strategy ;
        sh:class ieh:DecisionStrategy ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ieh:coverage ;
        sh:datatype xsd:double ;
        sh:minInclusive "0.0"^^xsd:double ;
        sh:maxInclusive "1.0"^^xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Personal Broker Shape
# ══════════════════════════════════════════════════════════════

ieh:PersonalBrokerShape a sh:NodeShape ;
    sh:targetClass ieh:PersonalBroker ;
    rdfs:comment "A personal broker must reference an AAT and a presence status." ;

    sh:property [
        sh:path ieh:agentAAT ;
        sh:class ieh:AbstractAgentType ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;

    sh:property [
        sh:path ieh:presence ;
        sh:class ieh:PresenceStatus ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Conversation Shape
# ══════════════════════════════════════════════════════════════

ieh:ConversationShape a sh:NodeShape ;
    sh:targetClass ieh:Conversation ;

    sh:property [
        sh:path ieh:participant ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:name "participant" ;
        sh:message "A conversation must have at least one participant."
    ] ;

    sh:property [
        sh:path prov:startedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

# ══════════════════════════════════════════════════════════════
#  Conversation Message Shape
# ══════════════════════════════════════════════════════════════

ieh:ConversationMessageShape a sh:NodeShape ;
    sh:targetClass ieh:ConversationMessage ;

    sh:property [
        sh:path prov:wasAttributedTo ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "from"
    ] ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "content"
    ] ;

    sh:property [
        sh:path prov:generatedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "timestamp"
    ] .
