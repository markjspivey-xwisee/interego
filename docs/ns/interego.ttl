@prefix ie:   <https://interego.dev/ns/interego#> .
@prefix cg:   <https://interego.dev/ns/cg#> .
@prefix pgsl: <https://interego.dev/ns/pgsl#> .
@prefix cgh:  <https://interego.dev/ns/harness#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ══════════════════════════════════════════════════════════════
#  Interego 1.0 — Interrogatives Core Ontology
# ══════════════════════════════════════════════════════════════
#
#  Interego is an improvisational signification platform: a
#  shared substrate where humans and agents pose interrogatives
#  to each other and co-construct meaning in real time.
#
#  This is the CORE ontology of Interego — the interrogatives
#  layer. It is the user-facing grammar that sits over the
#  technical machinery in the substrate (pgsl:), typed-context
#  descriptors (cg:), and agent harness (cgh:). Each of those
#  lower layers "answers" one or more interrogatives; the
#  interrogatives give those answers a common, typed vocabulary
#  so agents and humans can inquire, refine, reframe, and
#  respond without having to reason about layer boundaries.
#
#  The eleven canonical interrogatives are:
#
#     Who       agent / subject        — cg:AgentFacet
#     What      entity / object        — pgsl:Atom, pgsl:Fragment
#     Where     location / container   — cg:FederationFacet
#     When      time / duration        — cg:TemporalFacet
#     Why       cause / motive         — cg:ProvenanceFacet
#     How       method / means         — cg:ProvenanceFacet, pgsl:PullbackSquare
#     Which     selection / paradigm   — cgh:Decision
#     WhatKind  type / category        — cg:SemioticFacet
#     HowMuch   quantity / extent      — pgsl:level, cgh:confidence
#     Whose     ownership / control    — cg:AccessControlFacet
#     Whether   truth / modality       — cg:TrustFacet, cgh:PolicyDecision, cgh:RuntimeEval
#
#  These correspond to Kantian categories, Fillmore case grammar,
#  FrameNet semantic roles, and Greimasian narrative actants.
#
#  Philosophical foundation:
#    - Peircean triadic semiotics (sign / object / interpretant)
#    - Husserlian intersubjectivity ("inter-ego" = between selves)
#    - Bakhtinian dialogism (meaning is inherently responsive)
#    - Mead's symbolic interactionism
#    - Saussurean syntagm/paradigm (chain vs. choice)
#
#  Naming:
#    "Inter-ego" = between-selves. Interego positions itself as
#    the substrate that lives BETWEEN agents (human or AI) — the
#    shared ground where meaning is negotiated, not the private
#    storage of any one agent.
# ══════════════════════════════════════════════════════════════

<https://interego.dev/ns/interego#>
    a owl:Ontology ;
    owl:versionInfo "1.0" ;
    dct:title "Interego 1.0 — Interrogatives Core Ontology" ;
    dct:description "The core ontology of Interego, the improvisational signification platform. Defines the eleven canonical interrogatives (Who, What, Where, When, Why, How, Which, WhatKind, HowMuch, Whose, Whether) as a SKOS concept scheme; the act of posing an interrogative and its response (both aligned with PROV-O); the Peircean semiotic triad of Sign, Object, and Interpretant; and the unit of emergent meaning (Signification). Each existing technical layer of Interego — the substrate, the typed-context descriptors, and the agent harness — answers specific interrogatives. This ontology provides the user-facing grammar over that technical machinery." ;
    dct:creator "Interego" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:created "2026-04-14"^^xsd:date ;
    dct:modified "2026-04-14"^^xsd:date ;
    vann:preferredNamespacePrefix "ie" ;
    vann:preferredNamespaceUri "https://interego.dev/ns/interego#" ;
    owl:imports <http://www.w3.org/ns/prov-o> ,
                <https://interego.dev/ns/pgsl#> ,
                <https://interego.dev/ns/cg#> ,
                <https://interego.dev/ns/harness#> ;
    rdfs:seeAlso <https://interego.dev/ns/alignment#> .

# ══════════════════════════════════════════════════════════════
#  PART 1 — Interrogative Types (SKOS concept scheme)
# ══════════════════════════════════════════════════════════════
#
#  The eleven canonical interrogatives are modeled as a SKOS
#  concept scheme so they can be referenced, extended, and
#  aligned with external vocabularies (FrameNet, Case Grammar,
#  thematic roles, Kantian categories) without committing to
#  them being OWL classes.
#
#  A real question posed by an agent is an ie:Act whose
#  ie:interrogativeType references one or more of these concepts.

ie:Interrogative a owl:Class , skos:ConceptScheme ;
    rdfs:label "Interrogative" ;
    rdfs:comment "The abstract parent for all interrogative types. Also a SKOS concept scheme — the eleven canonical interrogatives are skos:Concept instances of this class. An Interrogative is not a question in natural language; it is the TYPE of question, the semantic category that a given question falls into. Real questions posed by agents are modeled as ie:Act instances whose ie:interrogativeType is one of these types." ;
    skos:hasTopConcept
        ie:Who ,
        ie:What ,
        ie:Where ,
        ie:When ,
        ie:Why ,
        ie:How ,
        ie:Which ,
        ie:WhatKind ,
        ie:HowMuch ,
        ie:Whose ,
        ie:Whether ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ── The eleven canonical types ────────────────────────────────

ie:Who a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Who" ;
    skos:definition "Agent/subject interrogative. Asks about the identity of an agent involved in an event, proposition, or assertion. Answered by cg:AgentFacet in the typed-context layer and by prov:Agent in provenance traces." ;
    skos:altLabel "Subject" , "Agent" , "Actor" ;
    skos:example "Who did this? Who is asserting this? Who was present?" .

ie:What a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "What" ;
    skos:definition "Entity/object interrogative. Asks about the referent of a sign — what thing is being discussed. Answered by pgsl:Atom (atomic value) and pgsl:Fragment (composite structure) in the substrate layer." ;
    skos:altLabel "Entity" , "Object" , "Thing" ;
    skos:example "What is this? What happened? What does X mean?" .

ie:Where a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Where" ;
    skos:definition "Spatial/locational interrogative. Asks about location, container, or place — including non-geographic containers like pods, graphs, or organizational boundaries. Answered by cg:FederationFacet (where is this hosted?) and by container relationships in the substrate." ;
    skos:altLabel "Location" , "Place" , "Container" ;
    skos:example "Where is this stored? Where did this happen? In what context?" .

ie:When a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "When" ;
    skos:definition "Temporal interrogative. Asks about time — instants, intervals, durations, and temporal relations. Answered by cg:TemporalFacet of context descriptors, aligned with OWL-Time." ;
    skos:altLabel "Time" , "Moment" , "Duration" ;
    skos:example "When did this happen? How long did it last? Is it still valid?" .

ie:Why a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Why" ;
    skos:definition "Causal/motivational interrogative. Asks about reasons — both proximate causes (the mechanism that produced an outcome) and motivating reasons (the goal or intention behind an action). Answered by cg:ProvenanceFacet (causal provenance) and by cgh:Decision justification (motivating reasons)." ;
    skos:altLabel "Reason" , "Cause" , "Motive" , "Purpose" ;
    skos:example "Why did this happen? Why was this decision made? Why is this true?" .

ie:How a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "How" ;
    skos:definition "Methodical/procedural interrogative. Asks about means, method, or manner — the procedure by which something came to be or the way it is structured. Answered by cg:ProvenanceFacet (how it was produced), pgsl:PullbackSquare (how it is composed), and cgh:strategyUsed (how the harness approached a question)." ;
    skos:altLabel "Method" , "Means" , "Manner" , "Procedure" ;
    skos:example "How did this happen? How was it built? How do I do X?" .

ie:Which a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Which" ;
    skos:definition "Selection/paradigmatic interrogative. Asks for a choice from a known set of alternatives — the Saussurean paradigm axis. Distinct from ie:What (which asks open-endedly) in that ie:Which assumes a closed set of options. Answered by cgh:Decision (which action to take) and by cg:restriction (which facets to include in a composition)." ;
    skos:altLabel "Selection" , "Choice" , "Alternative" ;
    skos:example "Which of these options? Which choice should I make?" .

ie:WhatKind a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "What kind" ;
    skos:definition "Typological interrogative. Asks about the type, category, or class of a thing. Answered by cg:SemioticFacet (under what interpretive frame?) and by rdf:type / skos:Concept membership." ;
    skos:altLabel "Type" , "Category" , "Class" , "Sort" ;
    skos:example "What kind of thing is this? What category does it belong to?" .

ie:HowMuch a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "How much" ;
    skos:definition "Quantitative interrogative. Asks about quantity, extent, magnitude, or degree. Includes both continuous (how much water) and discrete (how many items) variants. Answered by pgsl:level / pgsl:atomCount / pgsl:fragmentCount (substrate cardinality) and by cgh:confidence (degree of certainty)." ;
    skos:altLabel "How many" , "Quantity" , "Extent" , "Magnitude" ;
    skos:example "How much? How many? To what extent?" .

ie:Whose a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Whose" ;
    skos:definition "Possessive/ownership interrogative. Asks about control, stewardship, or possession — who has the authority to modify, access, or speak for something. Answered by cg:AccessControlFacet (access rights) and cg:AgentFacet onBehalfOf delegation." ;
    skos:altLabel "Ownership" , "Control" , "Stewardship" ;
    skos:example "Whose data is this? Who controls this graph? On whose behalf?" .

ie:Whether a skos:Concept , ie:Interrogative ;
    skos:inScheme ie:Interrogative ;
    skos:prefLabel "Whether" ;
    skos:definition "Modal interrogative. Asks about truth, possibility, permission, or likelihood. Encompasses yes/no questions, epistemic modality (is it true?), deontic modality (is it permitted?), and alethic modality (is it possible?). Answered by cg:TrustFacet (how certain?), cgh:PolicyDecision (is it permitted?), and cgh:RuntimeEval (is the answer reliable?)." ;
    skos:altLabel "Yes/No" , "Truth" , "Modality" , "Possibility" , "Permission" ;
    skos:example "Is this true? May I do this? Is it possible?" .

# ══════════════════════════════════════════════════════════════
#  PART 2 — Interrogative Acts and Responses
# ══════════════════════════════════════════════════════════════
#
#  An Interrogative is a TYPE; an Act is a particular instance of
#  posing an interrogative at a particular time by a particular
#  agent. Acts form the edges of a dialog graph.

ie:Act a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Interrogative Act" ;
    rdfs:comment "A speech act of posing an interrogative. Records who asked (posedBy), optionally who they asked (posedTo), what kind of interrogative (interrogativeType), and what the question is about (about). Modeled as a prov:Activity so PROV tooling can walk dialog lineage and so policy decisions, traces, and evaluations can all be attached uniformly." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:Response a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Response" ;
    rdfs:comment "Content offered in response to an Interrogative Act. Grounded in substrate data (ie:grounds), attributed to a responding agent (prov:wasAttributedTo), and optionally evaluated for confidence (ie:confidence). A Response is never final — it can itself provoke further Acts that refine or reframe the original question." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ── Act properties ────────────────────────────────────────────

ie:posedBy a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:label "posed by" ;
    rdfs:comment "The agent who posed this interrogative act. Functional — each act has exactly one asker. Subproperty of prov:wasAssociatedWith so PROV tooling can find the asker via standard queries." ;
    rdfs:domain ie:Act ;
    rdfs:range prov:Agent ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:posedTo a owl:ObjectProperty ;
    rdfs:label "posed to" ;
    rdfs:comment "The agent or group the interrogative is directed at. Optional — absent when the question is posed to no one in particular (e.g. a monologue or a rhetorical question). Multi-valued — a question can be posed to multiple recipients." ;
    rdfs:domain ie:Act ;
    rdfs:range prov:Agent ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:interrogativeType a owl:ObjectProperty ;
    rdfs:label "interrogative type" ;
    rdfs:comment "The kind(s) of interrogative this act poses. Multi-valued because a single natural-language question often combines multiple interrogatives (e.g. 'when did Alice tell me about it?' combines Who, What, and When)." ;
    rdfs:domain ie:Act ;
    rdfs:range ie:Interrogative ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:about a owl:ObjectProperty ;
    rdfs:label "about" ;
    rdfs:comment "The focal entity or entities the interrogative is about. Typically a pgsl:Node (substrate data) or cg:ContextDescriptor (typed context). Gives the act a concrete target; distinct from the interrogative TYPE which is abstract." ;
    rdfs:domain ie:Act ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:refines a owl:ObjectProperty ;
    rdfs:label "refines" ;
    rdfs:comment "This act narrows or specifies a prior act. The refining act is always more specific than the one it refines — the interrogative type may stay the same but the scope contracts (e.g. 'what did Alice say?' refines 'who said what?'). Forms a directed acyclic graph of dialog evolution." ;
    rdfs:domain ie:Act ;
    rdfs:range ie:Act ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:reframes a owl:ObjectProperty ;
    rdfs:label "reframes" ;
    rdfs:comment "This act changes the interpretive frame of a prior act — swaps paradigms, replaces presuppositions, or shifts the semantic register. A reframe is a more aggressive move than a refinement: the relationship between the old and new question is not one of containment but of perspective change. In Saussurean terms, a reframe changes the paradigmatic axis." ;
    rdfs:domain ie:Act ;
    rdfs:range ie:Act ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:answeredBy a owl:ObjectProperty ;
    rdfs:label "answered by" ;
    rdfs:comment "Links an Act to a Response that addresses it. Multi-valued — an act can have many responses from different agents, or the same agent can offer refinements over time." ;
    rdfs:domain ie:Act ;
    rdfs:range ie:Response ;
    owl:inverseOf ie:responseTo ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ── Response properties ──────────────────────────────────────

ie:responseTo a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "response to" ;
    rdfs:comment "Links a Response back to the Act it addresses. Functional — a single response responds to exactly one primary act. If a response happens to also address other acts, record that via additional ie:answers triples." ;
    rdfs:domain ie:Response ;
    rdfs:range ie:Act ;
    owl:inverseOf ie:answeredBy ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:grounds a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:label "grounds" ;
    rdfs:comment "The substrate data this response draws upon. Typically pgsl:Node instances (atoms or fragments). Subproperty of prov:used so the response's inputs are discoverable via standard PROV walks. A response with no ie:grounds is a pure claim; a response with grounds is traceable back to primary data." ;
    rdfs:domain ie:Response ;
    rdfs:range pgsl:Node ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:confidence a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "Confidence in [0.0, 1.0] associated with a response. Typically computed by cgh:RuntimeEval and carried over to the response. Functional — each response has one confidence value." ;
    rdfs:domain ie:Response ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ══════════════════════════════════════════════════════════════
#  PART 3 — Peircean Semiotic Triad
# ══════════════════════════════════════════════════════════════
#
#  Interego rests on Peircean semiotics: meaning is triadic.
#  A Sign points to an Object via an Interpretant. The
#  Interpretant is always agent-relative — the meaning a
#  particular interpreter derives. Interego treats signs,
#  objects, and interpretants as first-class resources so
#  multi-agent disagreement about meaning can be represented,
#  traced, and negotiated rather than silently averaged away.

ie:Sign a owl:Class ;
    rdfs:label "Sign" ;
    rdfs:comment "An interpretable token — whatever an agent takes to stand for something else. Peircean signs are NOT linguistic only; they include gestures, data patterns, sensor readings, and (recursively) other signs. In Interego, pgsl: atoms and fragments are frequently treated as signs when an agent interprets them." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:Object a owl:Class ;
    rdfs:label "Semiotic Object" ;
    rdfs:comment "The thing a sign is about — what Peirce called the 'dynamic object'. Distinct from the sign itself, and distinct from any particular agent's interpretation. In practice, objects are often pgsl:Node instances (substrate data) or cg:ContextDescriptor references." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:Interpretant a owl:Class ;
    rdfs:label "Interpretant" ;
    rdfs:comment "The meaning a particular agent derives from a particular sign. CRITICAL: interpretants are agent-relative. Two agents reading the same sign may produce different interpretants — this is not an error but the fundamental structure of intersubjective meaning. Interego records interpretants as first-class resources so disagreements can be compared, reconciled, or preserved as productive ambiguity." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ── Triadic properties ───────────────────────────────────────

ie:signifies a owl:ObjectProperty ;
    rdfs:label "signifies" ;
    rdfs:comment "The primary sign-to-object relation. Reads: 'this sign signifies that object.' The relation is mediated by interpretants (see ie:interpretedBy) but for convenience the direct sign→object link is also recorded." ;
    rdfs:domain ie:Sign ;
    rdfs:range ie:Object ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:interpretedBy a owl:ObjectProperty ;
    rdfs:label "interpreted by" ;
    rdfs:comment "The interpretants a sign gives rise to. Multi-valued — a single sign can have many interpretants, one per agent (or per agent-context pair). This is where intersubjective disagreement lives." ;
    rdfs:domain ie:Sign ;
    rdfs:range ie:Interpretant ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:forAgent a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "for agent" ;
    rdfs:comment "The agent whose interpretant this is. Functional — each interpretant belongs to exactly one agent, because meaning is agent-relative. To represent a shared interpretation across agents, use multiple interpretant resources that reference the same content." ;
    rdfs:domain ie:Interpretant ;
    rdfs:range prov:Agent ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:derivesFrom a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "derives from" ;
    rdfs:comment "Links an interpretant back to the sign it interprets. Functional — each interpretant interprets exactly one primary sign (though chains of interpretants can interpret each other, forming 'semiotic chains' in Peirce's sense)." ;
    rdfs:domain ie:Interpretant ;
    rdfs:range ie:Sign ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

# ══════════════════════════════════════════════════════════════
#  PART 4 — Signification (emergent meaning)
# ══════════════════════════════════════════════════════════════
#
#  Signification is the unit of emergent, co-constructed meaning.
#  Where an Act is a single question and a Response is a single
#  answer, a Signification is the WHOLE that emerges from one or
#  more act-response exchanges — the coherent meaning that
#  participants retroactively recognize as what-was-said.
#
#  Signification is deliberately informal. It's a wrapper that
#  ties together the bits of substrate, context, and dialog that
#  together constitute a recognizable meaning unit. It is the
#  "improvisational" heart of Interego — the thing that emerges
#  unplanned from interrogative exchange.

ie:Signification a owl:Class ;
    rdfs:label "Signification" ;
    rdfs:comment "A unit of co-constructed meaning emerging from an interrogative exchange. Signification is NOT a pre-planned assertion — it is what participants retroactively recognize as having been jointly constructed. A signification emerges from one or more ie:Act / ie:Response exchanges (ie:emergesFrom), may improvise on prior significations (ie:improvisesOn), and is grounded in substrate data through its constituent responses. Significations are the atoms of meaning in Interego's improvisational signification platform." ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:emergesFrom a owl:ObjectProperty ;
    rdfs:label "emerges from" ;
    rdfs:comment "The acts and/or responses this signification retroactively binds together into a coherent meaning unit. Multi-valued — a signification typically emerges from multiple prior exchanges." ;
    rdfs:domain ie:Signification ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .

ie:improvisesOn a owl:ObjectProperty ;
    rdfs:label "improvises on" ;
    rdfs:comment "A signification may IMPROVISE on a prior signification — extending it in a direction not originally planned, much as a jazz musician improvises on a theme. The relationship is looser than rdfs:subClassOf or ie:refines — it captures the emergent, responsive, unscripted nature of real-time meaning construction. This property is what makes Interego an 'improvisational' platform rather than merely a dialog logger." ;
    rdfs:domain ie:Signification ;
    rdfs:range ie:Signification ;
    rdfs:isDefinedBy <https://interego.dev/ns/interego#> .
