@prefix iep:   <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#>.
@prefix owl:  <http://www.w3.org/2002/07/owl#>.
@prefix sh:   <http://www.w3.org/ns/shacl#>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix dct:  <http://purl.org/dc/terms/>.

# ══════════════════════════════════════════════════════════════
#  Interego 1.0 — Normative SHACL Shapes for iep:
#
#  Layer 1 (protocol, normative) — see spec/LAYERS.md.
#  Conformance test suite uses these shapes as oracles; see
#  spec/conformance/README.md.
#
#  These shapes encode the invariants that a conforming Interego
#  implementation MUST satisfy when producing or consuming
#  ContextDescriptors. Each shape is scoped, cited in the spec, and
#  paired with a conformance-suite fixture.
# ══════════════════════════════════════════════════════════════

<https://markjspivey-xwisee.github.io/interego/ns/iep-shapes>
    a owl:Ontology ;
    owl:versionInfo "1.0" ;
    dct:title "Interego 1.0 — Normative SHACL Shapes" ;
    dct:description "Normative SHACL shapes for the iep: core namespace." ;
    owl:imports <https://markjspivey-xwisee.github.io/interego/ns/iep> .

# ──────────────────────────────────────────────────────────────
#  1. SemioticFacet — modal-truth consistency
#
#  The modal-status / groundTruth pair is three-valued:
#    Asserted       ↔ groundTruth MUST be true
#    Counterfactual ↔ groundTruth MUST be false
#    Hypothetical   ↔ groundTruth MUST NOT be set
#    Quoted         ↔ groundTruth MAY be either (quote of external claim)
#    Retracted      ↔ groundTruth MUST be false (previously asserted)
#
#  Prevents a Hypothetical descriptor from being squashed into a
#  false Counterfactual and a Counterfactual from being queried as
#  if it were Asserted.
# ──────────────────────────────────────────────────────────────
iep:SemioticFacetModalTruthConsistencyShape a sh:NodeShape ;
    sh:targetClass iep:SemioticFacet ;
    sh:sparql [
        sh:message "SemioticFacet: Asserted requires groundTruth=true, Counterfactual requires groundTruth=false, Hypothetical MUST NOT set groundTruth." ;
        sh:prefixes iep: ;
        sh:select """
            PREFIX iep: <https://markjspivey-xwisee.github.io/interego/ns/iep#>
            SELECT $this ?modalStatus ?groundTruth WHERE {
              $this iep:modalStatus ?modalStatus .
              OPTIONAL { $this iep:groundTruth ?groundTruth . }
              FILTER (
                ( ?modalStatus = iep:Asserted       && ( !BOUND(?groundTruth) || ?groundTruth != true ) ) ||
                ( ?modalStatus = iep:Counterfactual && ( !BOUND(?groundTruth) || ?groundTruth != false ) ) ||
                ( ?modalStatus = iep:Hypothetical   && BOUND(?groundTruth) )
              )
            }
        """
    ] .

# ──────────────────────────────────────────────────────────────
#  2. TemporalFacet — future-validFrom warning
#
#  validFrom set to a future wall-clock time is legal at the protocol
#  level (scheduled claims are a real use case), but SHOULD surface
#  so readers know the claim is not yet in effect. Implementations
#  MAY downgrade this from Warning to Info if the descriptor also
#  carries explicit semantics indicating the future-date is intentional.
# ──────────────────────────────────────────────────────────────
iep:TemporalFacetNonFutureValidFromShape a sh:NodeShape ;
    sh:targetClass iep:TemporalFacet ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "TemporalFacet.validFrom is in the future — claim is not yet in effect. If intentional (scheduled claim), ignore this warning." ;
        sh:prefixes iep: ;
        sh:select """
            PREFIX iep: <https://markjspivey-xwisee.github.io/interego/ns/iep#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            SELECT $this ?validFrom WHERE {
              $this iep:validFrom ?validFrom .
              FILTER (?validFrom > NOW())
            }
        """
    ] .

# ──────────────────────────────────────────────────────────────
#  3. RevocationCondition — self-reference rejection
#
#  A descriptor whose revocation successor-query references its own
#  graph IRI is trying to revoke itself by its own existence — a
#  malformed bootstrap. Hard violation.
#
#  The shape uses regex against the SPARQL query text rather than
#  parsing the query; implementations MAY choose a more precise
#  parser-based check but MUST reject at minimum this string form.
# ──────────────────────────────────────────────────────────────
iep:RevocationConditionNoSelfReferenceShape a sh:NodeShape ;
    sh:targetClass iep:RevocationCondition ;
    sh:sparql [
        sh:message "Revocation successor query references the enclosing descriptor's own graph IRI — malformed (self-revoking by existence)." ;
        sh:prefixes iep: ;
        sh:select """
            PREFIX iep: <https://markjspivey-xwisee.github.io/interego/ns/iep#>
            SELECT $this ?query WHERE {
              ?descriptor iep:revokedIf|iep:revokedBy $this .
              ?descriptor iep:describes ?graphIri .
              $this iep:successorQuery ?query .
              FILTER (CONTAINS(STR(?query), STR(?graphIri)))
            }
        """
    ] .

# ──────────────────────────────────────────────────────────────
#  4. ContextDescriptor — six-facet invariant (core 1.0)
#
#  The 1.0 core requires one of each of the six canonical facets:
#  Temporal, Provenance, Agent, AccessControl, Semiotic, Trust,
#  Federation. Additional facets (e.g. Causal, Projection, future
#  RevocationFacet) are permitted but MUST NOT replace any of the
#  six core facets.
#
#  NOTE: extensions to Interego Protocol 1.0 (such as a RevocationFacet
#  proposal) relax "exactly six" to "at least six" without breaking
#  this shape — they'd add an additional at-most-one shape for the
#  new facet type. Don't conflate that future relaxation with a
#  current requirement.
# ──────────────────────────────────────────────────────────────
iep:DescriptorSixFacetShape a sh:NodeShape ;
    sh:targetClass iep:ContextDescriptor ;
    sh:property [
        sh:path iep:hasFacet ;
        sh:qualifiedValueShape [ sh:class iep:TemporalFacet ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ContextDescriptor MUST have exactly one TemporalFacet."
    ] ;
    sh:property [
        sh:path iep:hasFacet ;
        sh:qualifiedValueShape [ sh:class iep:ProvenanceFacet ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ContextDescriptor MUST have exactly one ProvenanceFacet."
    ] ;
    sh:property [
        sh:path iep:hasFacet ;
        sh:qualifiedValueShape [ sh:class iep:AgentFacet ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ContextDescriptor MUST have exactly one AgentFacet."
    ] ;
    sh:property [
        sh:path iep:hasFacet ;
        sh:qualifiedValueShape [ sh:class iep:SemioticFacet ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ContextDescriptor MUST have exactly one SemioticFacet."
    ] ;
    sh:property [
        sh:path iep:hasFacet ;
        sh:qualifiedValueShape [ sh:class iep:TrustFacet ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ContextDescriptor MUST have exactly one TrustFacet."
    ] .

# ──────────────────────────────────────────────────────────────
#  5. ProvenanceFacet ↔ AgentFacet — agent identity consistency
#
#  A descriptor that names agent X in its AgentFacet but whose
#  ProvenanceFacet's wasAssociatedWith points at agent Y is almost
#  always a bug — the writer forked identity somewhere. Warning
#  (not violation) because there are legitimate ghost-write patterns
#  (e.g. agent X proxying for agent Y) where this is intentional.
# ──────────────────────────────────────────────────────────────
iep:AgentProvenanceConsistencyShape a sh:NodeShape ;
    sh:targetClass iep:ContextDescriptor ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "AgentFacet.assertingAgent != ProvenanceFacet.wasAssociatedWith — identity fork detected. If intentional (ghost-write), ignore." ;
        sh:prefixes iep: ;
        sh:select """
            PREFIX iep: <https://markjspivey-xwisee.github.io/interego/ns/iep#>
            PREFIX prov: <http://www.w3.org/ns/prov#>
            SELECT $this ?aa ?pa WHERE {
              $this iep:hasFacet ?agentFacet .
              ?agentFacet a iep:AgentFacet ;
                          iep:assertingAgent/iep:agentIdentity ?aa .
              $this iep:hasFacet ?provFacet .
              ?provFacet a iep:ProvenanceFacet ;
                         iep:wasGeneratedBy ?activity .
              ?activity iep:agent ?pa .
              FILTER (?aa != ?pa)
            }
        """
    ] .

# ──────────────────────────────────────────────────────────────
#  6. Distribution — visibility / encryption consistency
#
#  iep:visibility classifies the audience for the affordance's payload:
#    public  ↔ iep:encrypted MUST be false  (plaintext readable by any
#                                            authenticated user via
#                                            foaf:Agent acl:Read)
#    shared  ↔ iep:encrypted MUST be true   (JOSE envelope wrapped to
#                                            the pod's authorized agents
#                                            plus optional share_with)
#    private ↔ iep:encrypted MUST be true   (JOSE envelope wrapped to the
#                                            publishing agent only)
#
#  Prevents a descriptor claiming "public" while shipping ciphertext
#  (no anonymous reader can decrypt) or claiming "shared"/"private"
#  while shipping plaintext (the audience-class promise is silently
#  violated). iep:visibility is optional — when absent, the shape is
#  inert and existing pre-visibility descriptors continue to pass.
#  Only one of the three legal string values is permitted.
# ──────────────────────────────────────────────────────────────
iep:VisibilityShape a sh:NodeShape ;
    sh:targetClass iep:Affordance ;
    sh:property [
        sh:path iep:visibility ;
        sh:datatype xsd:string ;
        sh:in ( "public" "shared" "private" ) ;
        sh:maxCount 1 ;
        sh:message "iep:visibility MUST be one of \"public\", \"shared\", or \"private\" (functional property — at most one value per distribution)."
    ] ;
    sh:sparql [
        sh:message "iep:visibility consistency: \"public\" requires iep:encrypted=false; \"shared\" and \"private\" require iep:encrypted=true." ;
        sh:prefixes iep: ;
        sh:select """
            PREFIX iep: <https://markjspivey-xwisee.github.io/interego/ns/iep#>
            SELECT $this ?visibility ?encrypted WHERE {
              $this iep:visibility ?visibility .
              $this iep:encrypted ?encrypted .
              FILTER (
                ( ?visibility = "public"  && ?encrypted != false ) ||
                ( ?visibility = "shared"  && ?encrypted != true  ) ||
                ( ?visibility = "private" && ?encrypted != true  )
              )
            }
        """
    ] .

# ──────────────────────────────────────────────────────────────
#  7. AuthorshipProof — required fields for iep:SignedAuthorship
#
#  When a descriptor embeds iep:authorshipProof [...], the embedded
#  blank node MUST declare every field the canonical-payload reconstructor
#  reads. Missing any of these makes the proof unverifiable from the
#  descriptor alone, defeating the whole point of embedded authorship.
#
#  Required:
#    iep:scheme              — signature suite name
#    iep:issuer              — agent IRI claiming authorship
#    iep:verificationMethod  — IRI naming the public key (did:ethr:<addr>)
#    iep:signerAddress       — authoritative public-id of the signer
#    iep:created             — ISO 8601 timestamp
#    iep:ownerWebId          — pod owner WebID
#    iep:descriptorId        — descriptor IRI the proof binds to
#    iep:proofValue          — the signature itself
#
#  Optional:
#    iep:agentDid            — DID-resolution hint
# ──────────────────────────────────────────────────────────────
iep:AuthorshipProofShape a sh:NodeShape ;
    sh:targetClass iep:SignedAuthorship ;
    sh:property [
        sh:path iep:scheme ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:scheme (signature suite)."
    ] ;
    sh:property [
        sh:path iep:issuer ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:issuer (agent IRI)."
    ] ;
    sh:property [
        sh:path iep:verificationMethod ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:verificationMethod (key IRI)."
    ] ;
    sh:property [
        sh:path iep:signerAddress ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:signerAddress."
    ] ;
    sh:property [
        sh:path iep:created ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:created (ISO 8601 timestamp)."
    ] ;
    sh:property [
        sh:path iep:ownerWebId ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:ownerWebId."
    ] ;
    sh:property [
        sh:path iep:descriptorId ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:descriptorId (the descriptor IRI the proof binds to)."
    ] ;
    sh:property [
        sh:path iep:proofValue ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "iep:SignedAuthorship MUST declare iep:proofValue (the signature)."
    ] ;
    sh:property [
        sh:path iep:agentDid ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "iep:agentDid is optional but MUST be at most one when present."
    ] .
