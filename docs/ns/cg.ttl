# Legacy "Context Graphs" (cg:) compatibility alias for the Interego Protocol.
#
# The L1 protocol namespace was renamed from "Context Graphs" (cg:, /ns/cg#)
# to the Interego Protocol (iep:, /ns/iep#). This file is retained ONLY so that
# IRIs minted before the rename still dereference and are mapped, term-for-term,
# onto their canonical iep: successors. Do NOT author new data against cg:.
#
# Canonical ontology: docs/ns/iep.ttl  (https://markjspivey-xwisee.github.io/interego/ns/iep#)
@prefix cg:   <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
@prefix iep:  <https://markjspivey-xwisee.github.io/interego/ns/iep#>.
@prefix owl:  <http://www.w3.org/2002/07/owl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct:  <http://purl.org/dc/terms/>.

<https://markjspivey-xwisee.github.io/interego/ns/cg>
    a owl:Ontology ;
    owl:deprecated true ;
    dct:title "Context Graphs (deprecated) — legacy alias of the Interego Protocol" ;
    dct:description "Deprecated. Renamed to the Interego Protocol (iep:). Every cg: term is owl:equivalentTo its iep: successor; dereference https://markjspivey-xwisee.github.io/interego/ns/iep for the canonical ontology." ;
    rdfs:seeAlso <https://markjspivey-xwisee.github.io/interego/ns/iep> ;
    dct:isReplacedBy <https://markjspivey-xwisee.github.io/interego/ns/iep> .

# ── Term-for-term equivalence: cg:X ≡ iep:X ──────────────────────────
# Classes
cg:ContextDescriptor   owl:equivalentClass iep:ContextDescriptor .
cg:ComposedDescriptor  owl:equivalentClass iep:ComposedDescriptor .
cg:ContextFacet        owl:equivalentClass iep:ContextFacet .
cg:TemporalFacet       owl:equivalentClass iep:TemporalFacet .
cg:ProvenanceFacet     owl:equivalentClass iep:ProvenanceFacet .
cg:AgentFacet          owl:equivalentClass iep:AgentFacet .
cg:AccessControlFacet  owl:equivalentClass iep:AccessControlFacet .
cg:SemioticFacet       owl:equivalentClass iep:SemioticFacet .
cg:TrustFacet          owl:equivalentClass iep:TrustFacet .
cg:FederationFacet     owl:equivalentClass iep:FederationFacet .
cg:CausalFacet         owl:equivalentClass iep:CausalFacet .
cg:ProjectionFacet     owl:equivalentClass iep:ProjectionFacet .
cg:Affordance          owl:equivalentClass iep:Affordance .
cg:Holon               owl:equivalentClass iep:Holon .

# Properties (the load-bearing ones; all other cg: properties resolve via the
# shared base + this ontology's isReplacedBy pointer)
cg:describes      owl:equivalentProperty iep:describes .
cg:hasFacet       owl:equivalentProperty iep:hasFacet .
cg:supersedes     owl:equivalentProperty iep:supersedes .
cg:compositionOp  owl:equivalentProperty iep:compositionOp .
cg:operand        owl:equivalentProperty iep:operand .
cg:modalStatus    owl:equivalentProperty iep:modalStatus .
cg:trustLevel     owl:equivalentProperty iep:trustLevel .
cg:assertingAgent owl:equivalentProperty iep:assertingAgent .
cg:validFrom      owl:equivalentProperty iep:validFrom .
cg:validUntil     owl:equivalentProperty iep:validUntil .
