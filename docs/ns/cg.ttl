@prefix cg:   <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#>.
@prefix owl:  <http://www.w3.org/2002/07/owl#>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix dct:  <http://purl.org/dc/terms/>.
@prefix acl:  <http://www.w3.org/ns/auth/acl#>.
@prefix vc:   <https://www.w3.org/2018/credentials#>.
@prefix did:  <https://www.w3.org/ns/did#>.
@prefix dcat: <http://www.w3.org/ns/dcat#>.
@prefix ldp:  <http://www.w3.org/ns/ldp#>.
@prefix solid: <http://www.w3.org/ns/solid/terms#>.
@prefix hydra: <http://www.w3.org/ns/hydra/core#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix sh:   <http://www.w3.org/ns/shacl#>.
@prefix vs:   <http://www.w3.org/2003/06/sw-vocab-status/ns#>.

# ══════════════════════════════════════════════════════════════
#  Interego 1.0 Ontology
# ══════════════════════════════════════════════════════════════

<https://markjspivey-xwisee.github.io/interego/ns/cg#>
    a owl:Ontology ;
    owl:versionInfo "1.0" ;
    dct:title "Interego 1.0 Ontology" ;
    dct:description "A compositional framework for typed graph contexts over RDF 1.2 Named Graphs. Defines context descriptors with seven facet types (Temporal, Provenance, Agent, AccessControl, Semiotic, Trust, Federation), composition operators, and federation primitives for decentralized knowledge sharing between AI agents." ;
    dct:creator [
        a foaf:Organization ;
        foaf:name "Interego" ;
        foaf:homepage <https://markjspivey-xwisee.github.io/interego/>
    ] ;
    dct:license <https://opensource.org/licenses/MIT> ;
    dct:created "2026-03-17"^^xsd:date ;
    dct:modified "2026-03-20"^^xsd:date ;
    vann:preferredNamespacePrefix "cg" ;
    vann:preferredNamespaceUri "https://markjspivey-xwisee.github.io/interego/ns/cg#" ;
    rdfs:seeAlso <https://markjspivey-xwisee.github.io/interego/spec/interego-1.0.html>.

# ══════════════════════════════════════════════════════════════
#  Classes
# ══════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────

cg:ContextDescriptor a owl:Class ;
    rdfs:label "Context Descriptor" ;
    rdfs:comment "A metadata envelope that annotates one or more RDF Named Graphs with typed context facets. Each descriptor declares provenance, temporal validity, semiotic frame, trust level, and federation metadata for the graphs it describes." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:ComposedDescriptor a owl:Class ;
    rdfs:subClassOf cg:ContextDescriptor ;
    rdfs:label "Composed Descriptor" ;
    rdfs:comment "A context descriptor produced by applying a composition operator (union, intersection, restriction, override) to two or more source descriptors. Preserves full provenance of operands." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Facets ────────────────────────────────────────────────────

cg:ContextFacet a owl:Class ;
    rdfs:label "Context Facet" ;
    rdfs:comment "Abstract base class for all context facet types. Each facet captures a specific dimension of context metadata." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:TemporalFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Temporal Facet" ;
    rdfs:comment "Temporal validity of a context. Aligned with OWL-Time and Dublin Core. Declares when the context is valid (validFrom/validUntil), temporal resolution, and relations to other temporal entities." ;
    rdfs:seeAlso time:TemporalEntity ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:ProvenanceFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Provenance Facet" ;
    rdfs:comment "Provenance metadata aligned with W3C PROV-O. Records who/what generated the context, when, and from what prior sources. Supports full provenance chains." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:AgentFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Agent Facet" ;
    rdfs:comment "Identifies the asserting agent and their role. Supports delegation (onBehalfOf) for AI agents acting on behalf of humans/organizations. Aligned with PROV-O Agent and ActivityStreams." ;
    rdfs:seeAlso prov:Agent ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:AccessControlFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Access Control Facet" ;
    rdfs:comment "Access control authorizations. Supports two modes in the same facet: (a) W3C WAC-shaped identity-based authorizations (who can Read, Write, Append, or Control) via acl:Authorization; and (b) attribute-based policy references via cg:policyRef → cg:AccessControlPolicy. Both modes coexist so deployments can migrate from ACL to ABAC incrementally." ;
    rdfs:seeAlso acl:Authorization ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:AccessControlPolicy a owl:Class ;
    rdfs:subClassOf cg:ContextDescriptor ;
    rdfs:label "Access Control Policy" ;
    rdfs:comment "An attribute-based access-control policy, expressed as a first-class context descriptor. A policy carries: (a) cg:policyPredicate — a SHACL shape the subject's attribute graph must satisfy; (b) cg:governedAction — the action (affordance / operation) the policy governs; (c) cg:deonticMode — one of cg:Permit, cg:Deny, cg:Duty; (d) optional cg:policyDuty — obligations to fulfil when Duty mode matches. Attribute sources for the subject can span the federation — the evaluation pattern for that resolution is specified by the abac: L2 ontology, but the structural primitives live here at L1 so that any implementation understands the same policy shape." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:DeonticMode a owl:Class ;
    rdfs:label "Deontic Mode" ;
    rdfs:comment "Modality of a policy rule: Permit, Deny, or Duty. Aligned with ODRL deontic semantics (odrl:Permission / odrl:Prohibition / odrl:Duty) so policies are interoperable with ODRL expressions, without requiring the full ODRL vocabulary as a runtime dependency." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Permit a cg:DeonticMode ;
    rdfs:label "Permit" ;
    rdfs:comment "The policy authorizes the governed action when its predicate is satisfied." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Deny a cg:DeonticMode ;
    rdfs:label "Deny" ;
    rdfs:comment "The policy forbids the governed action when its predicate is satisfied. Deny overrides Permit in composition." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Duty a cg:DeonticMode ;
    rdfs:label "Duty" ;
    rdfs:comment "The policy attaches an obligation that MUST be fulfilled alongside the governed action when the predicate is satisfied. Duties accumulate across matching rules." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:SemioticFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Semiotic Facet" ;
    rdfs:comment "Semiotic and epistemic metadata grounded in Peircean triadic semiotics. Captures the interpretive frame, modal status (Asserted, Hypothetical, Counterfactual, etc.), epistemic confidence [0.0-1.0], and whether the content represents ground truth." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:TrustFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Trust Facet" ;
    rdfs:comment "Trust and verifiability metadata aligned with W3C Verifiable Credentials 2.0 and DID Core. Declares trust level, issuer identity, proof mechanism, and optional verifiable credential reference." ;
    rdfs:seeAlso vc:VerifiableCredential ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:FederationFacet a owl:Class ;
    rdfs:subClassOf cg:ContextFacet ;
    rdfs:label "Federation Facet" ;
    rdfs:comment "Federation and distribution metadata aligned with DCAT 3, LDP, and Solid Protocol. Declares where the context is stored, sync protocol, replication sources, and distribution endpoints." ;
    rdfs:seeAlso solid:StorageDescription, dcat:Distribution ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Manifest & Federation ─────────────────────────────────────

cg:ManifestEntry a owl:Class ;
    rdfs:label "Manifest Entry" ;
    rdfs:comment "An entry in a pod's.well-known/context-graphs manifest. Lightweight summary of a published context descriptor for discovery." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:PodDirectory a owl:Class ;
    rdfs:label "Pod Directory" ;
    rdfs:comment "A decentralized directory graph listing known Solid pods participating in a federation. Itself published as an RDF resource on a pod." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:DataProduct a owl:Class ;
    rdfs:label "Data Product" ;
    rdfs:comment "Alignment with DPROD. A context-graphs manifest declares itself as a data product with input/output ports." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Affordance a owl:Class ;
    rdfs:label "Affordance" ;
    rdfs:comment "A capability that a pod or manifest supports. Used for HATEOAS-style agent discovery of what operations are available." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:AuthorizedAgent a owl:Class ;
    rdfs:label "Authorized Agent" ;
    rdfs:comment "An AI agent or software tool authorized to act on behalf of a pod owner via delegation." ;
    rdfs:subClassOf prov:SoftwareAgent ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Composition & Context Types ───────────────────────────────

cg:ContextType a owl:Class ;
    rdfs:label "Context Type" ;
    rdfs:comment "Enumeration class for the seven facet type identifiers." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:CompositionOperator a owl:Class ;
    rdfs:label "Composition Operator" ;
    rdfs:comment "Algebraic operators for composing context descriptors. The four operators (union, intersection, restriction, override) form a bounded lattice." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Properties
# ══════════════════════════════════════════════════════════════

# ── Core descriptor properties ────────────────────────────────

cg:describes a owl:ObjectProperty ;
    rdfs:label "describes" ;
    rdfs:comment "Links a ContextDescriptor to the Named Graph(s) it annotates." ;
    rdfs:domain cg:ContextDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:hasFacet a owl:ObjectProperty ;
    rdfs:label "has facet" ;
    rdfs:comment "Links a ContextDescriptor to one of its context facets." ;
    rdfs:domain cg:ContextDescriptor ;
    rdfs:range cg:ContextFacet ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:hasFacetType a owl:ObjectProperty ;
    rdfs:label "has facet type" ;
    rdfs:comment "Declares which facet types are present in a manifest entry (lightweight discovery)." ;
    rdfs:domain cg:ManifestEntry ;
    rdfs:range cg:ContextType ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:comment "Version number of the context descriptor." ;
    rdfs:domain cg:ContextDescriptor ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes" ;
    rdfs:comment "Links a descriptor to the previous version(s) it replaces." ;
    rdfs:domain cg:ContextDescriptor ;
    rdfs:range cg:ContextDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:AgentCatalog a owl:Class ;
    rdfs:label "Agent Catalog" ;
    rdfs:comment "A domain-level catalog of agents + pods published at <domain>/.well-known/interego-agents per spec §6.5d (progressive discovery T3). Carries one or more cg:hasAgent entries enumerating agents the domain operator wishes to advertise. Consumers use this to discover agents without needing to know specific pod URLs upfront." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:hasAgent a owl:ObjectProperty ;
    rdfs:label "has agent" ;
    rdfs:comment "Links a cg:AgentCatalog to an agent entry (typically a blank node or IRI typed cg:AuthorizedAgent). Used in the T3 agents-catalog format." ;
    rdfs:domain cg:AgentCatalog ;
    rdfs:range cg:AuthorizedAgent ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:webId a owl:ObjectProperty ;
    rdfs:label "WebID" ;
    rdfs:comment "The agent or principal's WebID (Solid profile URL). Used in agent-catalog entries and anywhere a WebID needs to be stated as a typed cg: property alongside did:/foaf: alternatives." ;
    rdfs:range cg:AuthorizedAgent ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:constructedFrom a owl:ObjectProperty ;
    rdfs:label "constructed from" ;
    rdfs:comment "Derivation-discipline predicate (spec/DERIVATION.md). Declares that the subject class / property is constructed at runtime from the named L1 primitives. Objects are typically an rdf:List of one or more L1 class or property IRIs. Used by tools/derivation-lint.mjs to verify every L2/L3 term is grounded in the L1 substrate." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Temporal properties ───────────────────────────────────────

cg:validFrom a owl:DatatypeProperty ;
    rdfs:label "valid from" ;
    rdfs:comment "Start of the temporal validity interval." ;
    rdfs:range xsd:dateTime ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:validUntil a owl:DatatypeProperty ;
    rdfs:label "valid until" ;
    rdfs:comment "End of the temporal validity interval." ;
    rdfs:range xsd:dateTime ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:temporalResolution a owl:DatatypeProperty ;
    rdfs:label "temporal resolution" ;
    rdfs:comment "Granularity of the temporal validity (e.g. xsd:duration)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:temporalRelation a owl:ObjectProperty ;
    rdfs:label "temporal relation" ;
    rdfs:comment "OWL-Time relation to another temporal entity." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Provenance properties ─────────────────────────────────────

cg:provenanceChain a owl:ObjectProperty ;
    rdfs:label "provenance chain" ;
    rdfs:comment "Ordered list of prior provenance activities." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Agent properties ──────────────────────────────────────────

cg:assertingAgent a owl:ObjectProperty ;
    rdfs:label "asserting agent" ;
    rdfs:comment "The agent asserting this context." ;
    rdfs:domain cg:AgentFacet ;
    rdfs:range prov:Agent ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:onBehalfOf a owl:ObjectProperty ;
    rdfs:label "on behalf of" ;
    rdfs:comment "The principal (human/org) the agent acts on behalf of." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:agentRole a owl:ObjectProperty ;
    rdfs:label "agent role" ;
    rdfs:comment "Role of the asserting agent (Author, Curator, Validator, etc.)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:agentIdentity a owl:ObjectProperty ;
    rdfs:label "agent identity" ;
    rdfs:comment "The identity IRI (DID, WebID) of an agent." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:authorizedAgent a owl:ObjectProperty ;
    rdfs:label "authorized agent" ;
    rdfs:comment "Links a pod owner profile to an authorized agent." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:delegatedBy a owl:ObjectProperty ;
    rdfs:label "delegated by" ;
    rdfs:comment "The principal who delegated authority to this agent." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:scope a owl:DatatypeProperty ;
    rdfs:label "scope" ;
    rdfs:comment "Delegation scope: ReadWrite, ReadOnly, PublishOnly, or DiscoverOnly." ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Access Control / Policy properties ───────────────────────

cg:policyRef a owl:ObjectProperty ;
    rdfs:label "policy reference" ;
    rdfs:comment "Links an AccessControlFacet to one or more AccessControlPolicy descriptors that govern access to the described graph. Multiple policies compose per the deonticMode rules (Deny overrides Permit; Duties accumulate)." ;
    rdfs:domain cg:AccessControlFacet ;
    rdfs:range cg:AccessControlPolicy ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:policyPredicate a owl:ObjectProperty ;
    rdfs:label "policy predicate" ;
    rdfs:comment "A SHACL NodeShape that the subject's attribute graph MUST satisfy for the policy to apply. Attributes can be sourced across the federation — the resolution pattern is specified by the abac: L2 ontology." ;
    rdfs:domain cg:AccessControlPolicy ;
    rdfs:range sh:NodeShape ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:governedAction a owl:ObjectProperty ;
    rdfs:label "governed action" ;
    rdfs:comment "The action (affordance or operation) this policy governs. Typically an IRI for a cg:Affordance, hydra:Operation, or a domain-level action (e.g. code:merge, hr:approve)." ;
    rdfs:domain cg:AccessControlPolicy ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:deonticMode a owl:ObjectProperty ;
    rdfs:label "deontic mode" ;
    rdfs:comment "The policy's modality: cg:Permit, cg:Deny, or cg:Duty. See cg:DeonticMode." ;
    rdfs:domain cg:AccessControlPolicy ;
    rdfs:range cg:DeonticMode ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:policyDuty a owl:DatatypeProperty ;
    rdfs:label "policy duty" ;
    rdfs:comment "A human-readable obligation attached to a Duty-mode policy. Multiple duties accumulate. Interoperability with ODRL odrl:duty is expected at the evaluator layer." ;
    rdfs:domain cg:AccessControlPolicy ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Semiotic properties ───────────────────────────────────────

cg:interpretationFrame a owl:DatatypeProperty ;
    rdfs:label "interpretation frame" ;
    rdfs:comment "The interpretive frame under which the context should be understood." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:signSystem a owl:DatatypeProperty ;
    rdfs:label "sign system" ;
    rdfs:comment "The sign system or semiotic code used." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:groundTruth a owl:DatatypeProperty ;
    rdfs:label "ground truth" ;
    rdfs:comment "Whether this context represents verified ground truth." ;
    rdfs:range xsd:boolean ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:modalStatus a owl:ObjectProperty ;
    rdfs:label "modal status" ;
    rdfs:comment "The modal status of the assertion: Asserted, Hypothetical, Counterfactual, Quoted, or Retracted." ;
    rdfs:domain cg:SemioticFacet ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:epistemicConfidence a owl:DatatypeProperty ;
    rdfs:label "epistemic confidence" ;
    rdfs:comment "Confidence level in the assertion, from 0.0 (no confidence) to 1.0 (absolute certainty)." ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:languageTag a owl:DatatypeProperty ;
    rdfs:label "language tag" ;
    rdfs:comment "BCP 47 language tag for the context content." ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Trust properties ──────────────────────────────────────────

cg:verifiableCredential a owl:ObjectProperty ;
    rdfs:label "verifiable credential" ;
    rdfs:comment "IRI of a W3C Verifiable Credential backing the trust assertion." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:issuer a owl:ObjectProperty ;
    rdfs:label "issuer" ;
    rdfs:comment "The issuer of the trust assertion (typically a DID)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:proofMechanism a owl:DatatypeProperty ;
    rdfs:label "proof mechanism" ;
    rdfs:comment "The cryptographic proof mechanism used (e.g. Ed25519Signature2020)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:trustLevel a owl:ObjectProperty ;
    rdfs:label "trust level" ;
    rdfs:comment "Level of trust: SelfAsserted, ThirdPartyAttested, or CryptographicallyVerified." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:revocationStatus a owl:DatatypeProperty ;
    rdfs:label "revocation status" ;
    rdfs:comment "Whether the trust assertion has been revoked." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Federation properties ─────────────────────────────────────

cg:origin a owl:ObjectProperty ;
    rdfs:label "origin" ;
    rdfs:comment "The origin Solid pod URL where this context was first published." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:storageEndpoint a owl:ObjectProperty ;
    rdfs:label "storage endpoint" ;
    rdfs:comment "The LDP endpoint where the context graph is stored." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:syncProtocol a owl:ObjectProperty ;
    rdfs:label "sync protocol" ;
    rdfs:comment "The synchronization protocol used for federation (SolidNotifications, WebSub, LDN, Polling)." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:replicaOf a owl:ObjectProperty ;
    rdfs:label "replica of" ;
    rdfs:comment "IRI of the original resource this is a replica of." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:lastSynced a owl:DatatypeProperty ;
    rdfs:label "last synced" ;
    rdfs:comment "Timestamp of the last successful synchronization." ;
    rdfs:range xsd:dateTime ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Pod directory properties ──────────────────────────────────

cg:hasPod a owl:ObjectProperty ;
    rdfs:label "has pod" ;
    rdfs:comment "Links a PodDirectory to a pod entry." ;
    rdfs:domain cg:PodDirectory ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:podUrl a owl:ObjectProperty ;
    rdfs:label "pod URL" ;
    rdfs:comment "The URL of a Solid pod in a directory entry." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Affordance properties ─────────────────────────────────────

cg:affordance a owl:ObjectProperty ;
    rdfs:label "affordance" ;
    rdfs:comment "Declares an affordance (capability) that this resource supports." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:action a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "action" ;
    rdfs:comment "Names the cg:Affordance individual this affordance block instantiates (e.g. cg:canFetchPayload, cg:canDecrypt, cg:canPublish). Lets a Hydra operation carry a stable cg: identifier alongside the operation-specific hydra:method / hydra:target, so discovery clients can reference the affordance vocabulary without string-matching free-text titles." ;
    rdfs:domain cg:Affordance ;
    rdfs:range cg:Affordance ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:encrypted a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "encrypted" ;
    rdfs:comment "Whether the declared distribution's payload is encrypted. When true, clients must decrypt locally using a key registered as an authorized recipient (see cg:encryptionAlgorithm + envelope wrappedKeys)." ;
    rdfs:domain dcat:Distribution ;
    rdfs:range xsd:boolean ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:encryptionAlgorithm a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "encryption algorithm" ;
    rdfs:comment "The envelope's KDF + AEAD suite, e.g. 'X25519-XSalsa20-Poly1305'. Identifies the crypto-primitive combination so clients know which library/mode to use." ;
    rdfs:domain dcat:Distribution ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:recipientCount a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "recipient count" ;
    rdfs:comment "Count of wrapped keys inside the encrypted envelope. Discoverable metadata (doesn't leak identities) so clients can reason about key fan-out / audience size without decrypting." ;
    rdfs:domain dcat:Distribution ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Identity / Auth properties ────────────────────────────────

cg:walletAddress a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "wallet address" ;
    rdfs:comment "Lowercased 0x-prefixed Ethereum address registered as a verification method. Used to match SIWE signatures to an owner." ;
    rdfs:domain cg:EthereumWallet ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:credentialId a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "credential id" ;
    rdfs:comment "Base64url-encoded credential ID from a WebAuthn registration response. Stable across sign-ins for the same passkey." ;
    rdfs:domain cg:WebAuthnCredential ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:publicKey a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "public key" ;
    rdfs:comment "Base64url-encoded COSE public key for a WebAuthn credential." ;
    rdfs:domain cg:WebAuthnCredential ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:counter a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "counter" ;
    rdfs:comment "WebAuthn signature counter. Monotonically increases per sign-in; a non-increasing value on an authenticator that supports counters indicates possible cloning and rejects auth per spec." ;
    rdfs:domain cg:WebAuthnCredential ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:transports a owl:DatatypeProperty ;
    rdfs:label "transports" ;
    rdfs:comment "WebAuthn transport hints ('internal', 'hybrid', 'usb', 'nfc', 'ble') collected at registration and replayed at authentication to let the client pick the right authenticator without prompting." ;
    rdfs:domain cg:WebAuthnCredential ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:did a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "did" ;
    rdfs:comment "The W3C DID (e.g. 'did:key:z...' or 'did:web:host:users:name') registered as a verification method." ;
    rdfs:domain cg:DIDKey ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:keyType a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "key type" ;
    rdfs:comment "Key type identifier per W3C Security Vocabulary. Currently 'Ed25519VerificationKey2020'." ;
    rdfs:domain cg:DIDKey ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Encryption properties ─────────────────────────────────────

cg:envelope a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "envelope" ;
    rdfs:comment "Base64-encoded JSON of the underlying encryption envelope (nacl.box format in current emission). Kept as a literal so Turtle serialization stays grammar-simple; consumers base64-decode + JSON.parse to reconstruct the envelope object." ;
    rdfs:domain cg:EncryptedValue ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:expectedDatatype a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "expected datatype" ;
    rdfs:comment "Optional hint of the post-decryption literal's datatype (e.g. 'xsd:dateTime', 'xsd:double') so clients can rebuild typed RDF literals after decrypting." ;
    rdfs:domain cg:EncryptedValue ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:encryptionPublicKey a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "encryption public key" ;
    rdfs:comment "Base64 X25519 public key announcing this agent as a valid envelope recipient. Publishers collecting this property across all cg:AuthorizedAgent rows on a pod get the pod's current recipient set." ;
    rdfs:domain cg:AuthorizedAgent ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Cross-pod sharing property ────────────────────────────────

cg:sharedWith a owl:ObjectProperty ;
    rdfs:label "shared with" ;
    rdfs:comment "Declares that this descriptor's payload is encrypted for the listed external identities (DIDs / WebIDs). Discovery-level metadata — the actual envelope wrappedKeys are the authoritative recipient list, but cg:sharedWith lets listeners filter / attribute the cross-pod sharing intent without decrypting." ;
    rdfs:domain cg:ContextDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:outputPort a owl:ObjectProperty ;
    rdfs:label "output port" ;
    rdfs:comment "DPROD alignment: output distribution endpoint for a data product." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:inputPort a owl:ObjectProperty ;
    rdfs:label "input port" ;
    rdfs:comment "DPROD alignment: input endpoint for a data product." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Composition properties ────────────────────────────────────

cg:compositionOp a owl:ObjectProperty ;
    rdfs:label "composition operator" ;
    rdfs:comment "The composition operator used to produce a ComposedDescriptor." ;
    rdfs:domain cg:ComposedDescriptor ;
    rdfs:range cg:CompositionOperator ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:operand a owl:ObjectProperty ;
    rdfs:label "operand" ;
    rdfs:comment "Source descriptor used as input to a composition operation." ;
    rdfs:domain cg:ComposedDescriptor ;
    rdfs:range cg:ContextDescriptor ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:restrictToType a owl:ObjectProperty ;
    rdfs:label "restrict to type" ;
    rdfs:comment "Facet type(s) to retain in a restriction composition." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Named Individuals
# ══════════════════════════════════════════════════════════════

# ── Context Types ─────────────────────────────────────────────

cg:Temporal a cg:ContextType ;
    rdfs:label "Temporal" ;
    rdfs:comment "Context type for temporal validity metadata.".

cg:Provenance a cg:ContextType ;
    rdfs:label "Provenance" ;
    rdfs:comment "Context type for provenance metadata (PROV-O).".

cg:Agent a cg:ContextType ;
    rdfs:label "Agent" ;
    rdfs:comment "Context type for agent identity and role metadata.".

cg:AccessControl a cg:ContextType ;
    rdfs:label "Access Control" ;
    rdfs:comment "Context type for access control metadata (WAC).".

cg:Semiotic a cg:ContextType ;
    rdfs:label "Semiotic" ;
    rdfs:comment "Context type for semiotic and epistemic metadata.".

cg:Trust a cg:ContextType ;
    rdfs:label "Trust" ;
    rdfs:comment "Context type for trust and verifiability metadata.".

cg:Federation a cg:ContextType ;
    rdfs:label "Federation" ;
    rdfs:comment "Context type for federation and distribution metadata.".

# ── Composition Operators ─────────────────────────────────────

cg:union a cg:CompositionOperator ;
    rdfs:label "union" ;
    rdfs:comment "Merges all facets from both descriptors. Forms the join in the composition lattice.".

cg:intersection a cg:CompositionOperator ;
    rdfs:label "intersection" ;
    rdfs:comment "Retains only facet types present in both descriptors. Forms the meet in the composition lattice.".

cg:restriction a cg:CompositionOperator ;
    rdfs:label "restriction" ;
    rdfs:comment "Restricts to specified facet types only.".

cg:override a cg:CompositionOperator ;
    rdfs:label "override" ;
    rdfs:comment "Takes facets from the first descriptor, overriding with the second where types match.".

# ── Modal Status ──────────────────────────────────────────────

cg:Asserted a owl:NamedIndividual ;
    rdfs:label "Asserted" ;
    rdfs:comment "The content is presented as true/factual by the asserting agent.".

cg:Hypothetical a owl:NamedIndividual ;
    rdfs:label "Hypothetical" ;
    rdfs:comment "The content is presented as a hypothesis or possibility.".

cg:Counterfactual a owl:NamedIndividual ;
    rdfs:label "Counterfactual" ;
    rdfs:comment "The content describes a scenario known not to be the case.".

cg:Quoted a owl:NamedIndividual ;
    rdfs:label "Quoted" ;
    rdfs:comment "The content is quoted from another source without endorsement.".

cg:Retracted a owl:NamedIndividual ;
    rdfs:label "Retracted" ;
    rdfs:comment "The content was previously asserted but has been retracted.".

# ── Trust Levels ──────────────────────────────────────────────

cg:SelfAsserted a owl:NamedIndividual ;
    rdfs:label "Self-Asserted" ;
    rdfs:comment "Trust based on the identity of the asserting agent alone.".

cg:ThirdPartyAttested a owl:NamedIndividual ;
    rdfs:label "Third-Party Attested" ;
    rdfs:comment "Trust backed by a third-party attestation.".

cg:CryptographicallyVerified a owl:NamedIndividual ;
    rdfs:label "Cryptographically Verified" ;
    rdfs:comment "Trust backed by cryptographic proof (signed VC, DID-based verification).".

# ── Agent Roles ───────────────────────────────────────────────

cg:Author a owl:NamedIndividual ;
    rdfs:label "Author" ;
    rdfs:comment "The agent authored/produced the context.".

cg:Curator a owl:NamedIndividual ;
    rdfs:label "Curator" ;
    rdfs:comment "The agent curated or selected the context.".

cg:Validator a owl:NamedIndividual ;
    rdfs:label "Validator" ;
    rdfs:comment "The agent validated or reviewed the context.".

# ── Sync Protocols ────────────────────────────────────────────

cg:SolidNotifications a owl:NamedIndividual ;
    rdfs:label "Solid Notifications" ;
    rdfs:comment "Solid Notifications Protocol (WebSocket or Webhook) for real-time context change events.".

cg:WebSub a owl:NamedIndividual ;
    rdfs:label "WebSub" ;
    rdfs:comment "W3C WebSub for publish-subscribe federation.".

cg:LinkedDataNotifications a owl:NamedIndividual ;
    rdfs:label "Linked Data Notifications" ;
    rdfs:comment "W3C LDN for sending notifications between pods.".

cg:Polling a owl:NamedIndividual ;
    rdfs:label "Polling" ;
    rdfs:comment "HTTP polling for change detection (fallback).".

# ── Affordance Individuals ────────────────────────────────────

cg:canPublish a cg:Affordance ;
    rdfs:label "Can Publish" ;
    rdfs:comment "This endpoint supports publishing new context descriptors.".

cg:canDiscover a cg:Affordance ;
    rdfs:label "Can Discover" ;
    rdfs:comment "This endpoint supports discovering context descriptors.".

cg:canSubscribe a cg:Affordance ;
    rdfs:label "Can Subscribe" ;
    rdfs:comment "This endpoint supports WebSocket subscription for live notifications.".

cg:canFetchPayload a cg:Affordance ;
    rdfs:label "Can Fetch Payload" ;
    rdfs:comment "This descriptor declares a graph payload retrievable at an accessURL. The client follows the hydra:target / dcat:accessURL of the attached cgh:Affordance (Hydra Operation) to retrieve the payload. Works for plaintext (TriG) and encrypted (JOSE envelope) distributions uniformly.".

cg:canDecrypt a cg:Affordance ;
    rdfs:label "Can Decrypt" ;
    rdfs:comment "The declared graph payload is encrypted; clients whose X25519 key is in the envelope's recipient list can decrypt locally. The cg:encryptionAlgorithm on the dcat:Distribution tells clients which KDF / AEAD pair to use. Only present when the Distribution is encrypted.".

cg:canAudit a cg:Affordance ;
    rdfs:label "Can Audit" ;
    rdfs:comment "This endpoint accepts an audit invocation targeting a descriptor (or descriptor set). Consumers GET / POST to hydra:target and receive an audit-result-v1-conforming response. Chained with the semantic-alignment auditor's recursive meta-audit pattern — invoking canAudit on an audit descriptor produces a meta-audit.".

cg:canPay a cg:Affordance ;
    rdfs:label "Can Pay" ;
    rdfs:comment "The declared resource is behind an x402-style payment challenge. Consumers receive 402 on initial GET with payment requirements (amount, asset, recipient, nonce, expiration); sign an authorization per §6.5a and retry with an X-Payment header. Settlement is out-of-band via the declared facilitator (Base USDC for production x402).".

cg:canVerify a cg:Affordance ;
    rdfs:label "Can Verify" ;
    rdfs:comment "This endpoint verifies a signature, proof, or attestation. For ERC-8004 T1+ attestations, consumers POST the signed Turtle + expected signer address; the endpoint recovers the signer and returns { valid, recovered }. Works uniformly for EIP-191, EIP-712, and ECDSA recovery paths.".

cg:canCompose a cg:Affordance ;
    rdfs:label "Can Compose" ;
    rdfs:comment "This endpoint applies a composition operator (union / intersection / restriction / override per §3.4) to operand descriptors and returns the composed descriptor. The cg:compositionOp query parameter selects the operator; operand IRIs are supplied via repeated cg:operand parameters.".

# ── Identity / Auth-methods classes (pod-resident) ────────────

cg:AuthMethods a owl:Class ;
    rdfs:label "Auth Methods" ;
    rdfs:comment "The pod-resident JSON-LD document at <pod>/auth-methods.jsonld listing the verification methods (wallets, WebAuthn credentials, DID keys) a user has registered. Serves as the pod-layer agent-registry trust anchor: identity servers read it to resolve signature proofs, envelope publishers read it to determine recipient keys. User-owned because it lives in the user's pod." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:EthereumWallet a owl:Class ;
    rdfs:label "Ethereum Wallet" ;
    rdfs:comment "An ERC-4361 (SIWE) verifiable wallet registered under a user's cg:AuthMethods. Carries a lowercased 0x-prefixed address (cg:walletAddress). Signature proof is ECDSA over secp256k1 per SIWE." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:WebAuthnCredential a owl:Class ;
    rdfs:label "WebAuthn Credential" ;
    rdfs:comment "A registered passkey / platform authenticator per W3C WebAuthn Level 3. Carries credential id, COSE public key, counter, and transports. Proof is a WebAuthn assertion signed by the authenticator over a server-issued challenge." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:DIDKey a owl:Class ;
    rdfs:label "DID Key" ;
    rdfs:comment "A W3C DID Core key (did:key or did:web) registered as a verification method. Carries did, publicKeyMultibase, keyType (currently Ed25519VerificationKey2020). Proof is an Ed25519 signature over a server-issued nonce." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Encryption classes (envelope / field-level) ──────────────

cg:EncryptedValue a owl:Class ;
    rdfs:label "Encrypted Value" ;
    rdfs:comment "An opt-in field-level encryption wrapper embedding an X25519 envelope (nacl.box over a symmetric content key) so a single facet-field value can be encrypted to a specific recipient set. Used when a descriptor's facet contains sensitive data that shouldn't be plaintext even though facet types stay discoverable. Carries cg:envelope (base64 JSON) and optional cg:expectedDatatype." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:EncryptedGraphEnvelope a owl:Class ;
    rdfs:subClassOf dcat:Distribution ;
    rdfs:label "Encrypted Graph Envelope" ;
    rdfs:comment "An encrypted distribution of a named graph. Its bytes are a JSON document { content: { ciphertext, nonce, algorithm }, wrappedKeys: [{ recipientPublicKey, wrappedKey, ... }], algorithm, version }. Any recipient whose X25519 key is in wrappedKeys can decrypt the payload locally. Carried as dcat:mediaType 'application/jose+json'." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:GraphPayload a owl:Class ;
    rdfs:subClassOf dcat:Distribution ;
    rdfs:label "Graph Payload" ;
    rdfs:comment "A plaintext distribution of a named graph (typically TriG). Used when encryption is disabled for a specific descriptor. Clients reading dcat:mediaType 'application/trig' can parse directly." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ── Session log type (emitted by /save-session slash command) ─

cg:SessionLog a owl:Class ;
    rdfs:subClassOf cg:ContextDescriptor ;
    rdfs:label "Session Log" ;
    rdfs:comment "A descriptor type for cross-session agent memory — decisions, changes, open threads from a single working session so future sessions (this agent or others on the same pod) can recover context. Structure kept intentionally coarse (cg:decision, cg:change, cg:openThread predicates) — implementations free to extend per use case." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Operations, Requests, Responses (API surface types)
# ══════════════════════════════════════════════════════════════

cg:Operation a owl:Class ;
    rdfs:subClassOf hydra:Operation ;
    rdfs:label "Operation" ;
    rdfs:comment "Abstract parent for concrete cg: operation types. Interoperable with hydra:Operation so Hydra clients can dispatch without understanding cg: semantics." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:IngestOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Ingest Operation" ; rdfs:comment "An operation that ingests content into the PGSL lattice." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:IngestUrisOperation a owl:Class ; rdfs:subClassOf cg:IngestOperation ; rdfs:label "Ingest URIs Operation" ; rdfs:comment "Bulk-ingest operation that takes a list of URIs and fetches each before ingesting." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ComposeOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Compose Operation" ; rdfs:comment "Composition operator (union, intersection, restriction, override) applied over two or more descriptors." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:QueryOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Query Operation" ; rdfs:comment "SPARQL-style query over descriptors / the lattice." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:DecisionOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Decision Operation" ; rdfs:comment "Harness-driven decision operation (exploit / explore / abstain)." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:CoherenceCheckOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Coherence Check Operation" ; rdfs:comment "Inter-agent coherence verification operation." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ChainBuildOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Chain Build Operation" ; rdfs:comment "Constructs a reasoning chain over descriptors / fragments." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ConstrainOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Constrain Operation" ; rdfs:comment "Applies a paradigm constraint to narrow a paradigm set." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:PodAddOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Pod Add Operation" ; rdfs:comment "Adds a pod to the federation registry." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:PodDiscoverOperation a owl:Class ; rdfs:subClassOf cg:Operation ; rdfs:label "Pod Discover Operation" ; rdfs:comment "Discovers pods from a PodDirectory graph." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Request a owl:Class ; rdfs:label "Request" ; rdfs:comment "Abstract parent of request record types." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Response a owl:Class ; rdfs:label "Response" ; rdfs:comment "Abstract parent of response record types." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:IngestRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Ingest Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:IngestResponse a owl:Class ; rdfs:subClassOf cg:Response ; rdfs:label "Ingest Response" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ComposeRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Compose Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ComposeResponse a owl:Class ; rdfs:subClassOf cg:Response ; rdfs:label "Compose Response" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:QueryRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Query Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:QueryResponse a owl:Class ; rdfs:subClassOf cg:Response ; rdfs:label "Query Response" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:CoherenceRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Coherence Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ConstraintRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Constraint Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:PodAddRequest a owl:Class ; rdfs:subClassOf cg:Request ; rdfs:label "Pod Add Request" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Anchor receipts (content-addressed provenance)
# ══════════════════════════════════════════════════════════════

cg:Anchor a owl:Class ;
    rdfs:label "Anchor" ;
    rdfs:comment "A zero-copy receipt proving some property (pinning, signing, encryption, lattice ingestion, activity) about a resource without copying its content. Stored at <pod>/anchors/." ;
    rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:IpfsAnchor a owl:Class ; rdfs:subClassOf cg:Anchor ; rdfs:label "IPFS Anchor" ; rdfs:comment "Proof of IPFS pinning (CID + provider + pinnedAt)." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:SignatureAnchor a owl:Class ; rdfs:subClassOf cg:Anchor ; rdfs:label "Signature Anchor" ; rdfs:comment "Proof of digital signing." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:EncryptionAnchor a owl:Class ; rdfs:subClassOf cg:Anchor ; rdfs:label "Encryption Anchor" ; rdfs:comment "Proof that a resource was encrypted for a recipient set." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:PgslAnchor a owl:Class ; rdfs:subClassOf cg:Anchor ; rdfs:label "PGSL Anchor" ; rdfs:comment "Proof of PGSL ingestion (topFragment + atomCount + fragmentCount)." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ActivityAnchor a owl:Class ; rdfs:subClassOf cg:Anchor ; rdfs:label "Activity Anchor" ; rdfs:comment "Proof of an agent activity (tool, decision, operation completion)." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  SHACL Shape classes referenced from validation code
# ══════════════════════════════════════════════════════════════

cg:ContextDescriptorShape a sh:NodeShape ; rdfs:label "ContextDescriptor SHACL shape" ; sh:targetClass cg:ContextDescriptor ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:TemporalFacetShape a sh:NodeShape ; rdfs:label "TemporalFacet SHACL shape" ; sh:targetClass cg:TemporalFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ProvenanceFacetShape a sh:NodeShape ; rdfs:label "ProvenanceFacet SHACL shape" ; sh:targetClass cg:ProvenanceFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:AgentFacetShape a sh:NodeShape ; rdfs:label "AgentFacet SHACL shape" ; sh:targetClass cg:AgentFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:AccessControlFacetShape a sh:NodeShape ; rdfs:label "AccessControlFacet SHACL shape" ; sh:targetClass cg:AccessControlFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:SemioticFacetShape a sh:NodeShape ; rdfs:label "SemioticFacet SHACL shape" ; sh:targetClass cg:SemioticFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:TrustFacetShape a sh:NodeShape ; rdfs:label "TrustFacet SHACL shape" ; sh:targetClass cg:TrustFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:FederationFacetShape a sh:NodeShape ; rdfs:label "FederationFacet SHACL shape" ; sh:targetClass cg:FederationFacet ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ComposedDescriptorShape a sh:NodeShape ; rdfs:label "ComposedDescriptor SHACL shape" ; sh:targetClass cg:ComposedDescriptor ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:ParadigmConstraintShape a sh:NodeShape ; rdfs:label "ParadigmConstraint SHACL shape" ; sh:targetClass cg:ParadigmConstraint ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:PersistenceRecordShape a sh:NodeShape ; rdfs:label "PersistenceRecord SHACL shape" ; sh:targetClass cg:PersistenceRecord ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:CoherenceCertificateShape a sh:NodeShape ; rdfs:label "CoherenceCertificate SHACL shape" ; sh:targetClass cg:CoherenceCertificate ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Coherence (inter-agent verification)
# ══════════════════════════════════════════════════════════════

cg:CoherenceCertificate a owl:Class ; rdfs:label "Coherence Certificate" ; rdfs:comment "Record asserting two agents' fragments are coherent at a given time." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:CoherenceObstruction a owl:Class ; rdfs:label "Coherence Obstruction" ; rdfs:comment "Specific atom/position where two agents' fragments disagree." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:CoherenceStatus a owl:Class ; rdfs:label "Coherence Status" ; rdfs:comment "Enum: Equal, Divergent, Subset, Intersect, Union, Exclude." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:AtomCoherence a owl:Class ; rdfs:label "Atom Coherence" ; rdfs:comment "Per-atom coherence snapshot used when rolling up to fragment-level status." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

cg:Equal a cg:CoherenceStatus ; rdfs:label "Equal" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Divergent a cg:CoherenceStatus ; rdfs:label "Divergent" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Subset a cg:CoherenceStatus ; rdfs:label "Subset" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Intersect a cg:CoherenceStatus ; rdfs:label "Intersect" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Union a cg:CoherenceStatus ; rdfs:label "Union" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Exclude a cg:CoherenceStatus ; rdfs:label "Exclude" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Verified a owl:NamedIndividual ; rdfs:label "Verified" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Unexamined a owl:NamedIndividual ; rdfs:label "Unexamined" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

# ══════════════════════════════════════════════════════════════
#  Decision & Strategies
# ══════════════════════════════════════════════════════════════

cg:Decision a owl:Class ; rdfs:label "Decision" ; rdfs:comment "A recorded decision (selected affordance + strategy + justification)." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:DecisionStrategy a owl:Class ; rdfs:label "Decision Strategy" ; rdfs:comment "Enum class for Exploit / Explore / Abstain." ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Exploit a cg:DecisionStrategy ; rdfs:label "Exploit" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Explore a cg:DecisionStrategy ; rdfs:label "Explore" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.
cg:Abstain a cg:DecisionStrategy ; rdfs:label "Abstain" ; rdfs:isDefinedBy <https://markjspivey-xwisee.github.io/interego/ns/cg#>.

