node_modules/
dist/
*.tsbuildinfo
.env
.env.*

# Relay agent keypair — secret, lives in Container Apps secret store only.
relay-agent-key*.json

# MCP server dependencies and build output (installed/built separately)
mcp-server/node_modules/
mcp-server/dist/
mcp-server/LICENSE
foxxi-context-graphs-*.tgz
foxxi-context-graphs-mcp-*.tgz

# Example dependencies
examples/*/node_modules/
examples/*/solid-data/

# OS
.DS_Store
Thumbs.db
benchmarks/LongMemEval/
benchmarks/locomo/

# Benchmark run logs — large (300MB+ across 30+ files), regenerable.
# Keep curated result JSONs (eval-history.json etc.); ignore raw run logs.
benchmarks/*.log
benchmarks/.tmp-*

# Wipe/retry run logs — timestamped per-run output, regenerated each run.
wipe-log.txt
wipe-*.log
retry-*.log
wipe-logs/

# npm pack output (build artifacts, regeneratable from source)
interego-core-*.tgz

# vitest --coverage output (generated; HTML report ~12MB)
coverage/

# Demo run reports — regenerated each run; reports are per-invocation
# artifacts, not source.
demos/output/

# Playwright test runner output
deploy/mcp-relay/test-results/
deploy/mcp-relay/playwright-report/

# Operator-private multi-agent test scaffolding (per-machine agent IDs,
# MCP configs, launcher scripts). Each operator regenerates locally.
scripts/agent-*.bat
scripts/agent-*.json
scripts/mcp-config-*.json
scripts/run-mcp-multiagent-test.bat

# Python bytecode (integrations/*-memory plugins)
__pycache__/
*.pyc

.write-secret.tmp
.interego/

# Local agent scratch (patches, split helpers) — per-machine, not source.
.claude/

# Holodeck example state — wallets, MCP configs, run history (operator-local, secret).
.holodeck/
examples/holodeck/.holodeck/

# Editor backups + per-run example artifacts (regenerated each run).
*.bak
examples/tic-tac-toe-tournament/_server.log
examples/tic-tac-toe-tournament/_tournament.log
examples/tic-tac-toe-tournament/last-run.json
